{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "play.plnt.work" }],
      "destination": "/playground"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "play.plnt.work" }],
      "destination": "/playground"
    }
  ]
}

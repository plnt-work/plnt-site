---
/*
  Minimal monochrome SVG of one intent traversing the system.
  Single accent. Grayscale otherwise. No rainbow.
*/
---

<div class="graph-wrap">
  <svg viewBox="0 0 720 560" role="img" aria-label="Intent flow" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <marker id="arrow-m" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 Z" fill="#5d5c57"/>
      </marker>
      <marker id="arrow-acc" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 Z" fill="#7dd3a0"/>
      </marker>
    </defs>

    <!-- INTENT -->
    <g>
      <rect x="220" y="20" width="280" height="48" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="42" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="2" fill="#5d5c57">USER INTENT</text>
      <text x="360" y="60" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#ededea">"papers by 7am"</text>
    </g>
    <line x1="360" y1="68" x2="360" y2="98" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />

    <!-- SURFACE -->
    <g>
      <rect x="220" y="98" width="280" height="44" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="119" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#ededea">Surface</text>
      <text x="360" y="134" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#8c8b84">record run_id · open SSE</text>
    </g>
    <line x1="360" y1="142" x2="360" y2="170" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />

    <!-- PLANNER -->
    <g>
      <rect x="220" y="170" width="280" height="44" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="191" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#ededea">Planner LLM</text>
      <text x="360" y="206" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#8c8b84">route to specialist</text>
    </g>
    <line x1="360" y1="214" x2="360" y2="240" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />

    <!-- RESIDENT SPECIALIST -->
    <g>
      <rect x="220" y="240" width="280" height="48" fill="none" stroke="#7dd3a0" stroke-width="1"/>
      <text x="360" y="262" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="500" fill="#7dd3a0">research-librarian</text>
      <text x="360" y="278" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#8c8b84">resident · decide work plan</text>
    </g>
    <line x1="360" y1="288" x2="360" y2="316" stroke="#7dd3a0" stroke-width="1" stroke-dasharray="3 3" marker-end="url(#arrow-acc)" />
    <text x="372" y="305" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#7dd3a0">AgentSpec</text>

    <!-- SCOUT spec -->
    <g>
      <rect x="200" y="316" width="320" height="44" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="336" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#ededea">AgentSpec[ literature-scout ]</text>
      <text x="360" y="351" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#8c8b84">search · 12 candidates</text>
    </g>

    <line x1="280" y1="360" x2="180" y2="395" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />
    <line x1="360" y1="360" x2="360" y2="395" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />
    <line x1="440" y1="360" x2="540" y2="395" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />

    <g>
      <rect x="100" y="395" width="160" height="40" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="180" y="412" text-anchor="middle" font-family="Inter, sans-serif" font-size="11.5" font-weight="500" fill="#ededea">paper-reader</text>
      <text x="180" y="426" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#8c8b84">4 papers</text>
    </g>
    <g>
      <rect x="280" y="395" width="160" height="40" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="412" text-anchor="middle" font-family="Inter, sans-serif" font-size="11.5" font-weight="500" fill="#ededea">paper-reader</text>
      <text x="360" y="426" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#8c8b84">4 papers</text>
    </g>
    <g>
      <rect x="460" y="395" width="160" height="40" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="540" y="412" text-anchor="middle" font-family="Inter, sans-serif" font-size="11.5" font-weight="500" fill="#ededea">paper-reader</text>
      <text x="540" y="426" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#8c8b84">4 papers</text>
    </g>

    <line x1="180" y1="435" x2="320" y2="468" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />
    <line x1="360" y1="435" x2="360" y2="468" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />
    <line x1="540" y1="435" x2="400" y2="468" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />

    <g>
      <rect x="200" y="468" width="320" height="40" fill="none" stroke="#3d3c39" stroke-width="1"/>
      <text x="360" y="486" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#ededea">AgentSpec[ summarizer · deep ]</text>
      <text x="360" y="500" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#8c8b84">exo cluster</text>
    </g>

    <line x1="360" y1="508" x2="360" y2="535" stroke="#5d5c57" stroke-width="1" marker-end="url(#arrow-m)" />
    <text x="360" y="552" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#7dd3a0">~/Desktop/agent-memory-2026-06-13.md</text>
  </svg>
</div>

<style>
  .graph-wrap {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--rule);
    padding: 1.5rem;
    overflow: hidden;
  }
  .graph-wrap svg { display: block; width: 100%; height: auto; max-width: 720px; margin: 0 auto; }
</style>

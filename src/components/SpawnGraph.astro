---
/*
  SVG diagram of a single intent traversing the system.
  Boxes for actors, arrows for control flow, labels on edges.
  Fully responsive — scales by viewBox.
*/
---

<div class="graph-wrap">
  <svg viewBox="0 0 720 540" role="img" aria-label="Intent flow diagram" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 Z" fill="#6a6f78"/>
      </marker>
      <marker id="arrow-brand" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 Z" fill="#059669"/>
      </marker>
      <linearGradient id="bg-paper" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0" stop-color="#fafaf7" />
        <stop offset="1" stop-color="#f3f3ee" />
      </linearGradient>
    </defs>

    <rect width="720" height="540" fill="url(#bg-paper)" />

    <!-- INTENT (user) -->
    <g>
      <rect x="260" y="20" width="200" height="50" rx="8" fill="#fff" stroke="#d6d3cc" stroke-width="1.2"/>
      <text x="360" y="42" text-anchor="middle" font-family="Inter, system-ui" font-size="13" font-weight="600" fill="#0f1115">user intent</text>
      <text x="360" y="60" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#6a6f78">"papers by 7am"</text>
    </g>
    <line x1="360" y1="70" x2="360" y2="100" stroke="#6a6f78" stroke-width="1.4" marker-end="url(#arrow)" />

    <!-- SURFACE -->
    <g>
      <rect x="260" y="100" width="200" height="44" rx="8" fill="#eff6ff" stroke="#3b82f6" stroke-width="1.2"/>
      <text x="360" y="120" text-anchor="middle" font-family="Inter, system-ui" font-size="12" font-weight="600" fill="#1e40af">Surface</text>
      <text x="360" y="136" text-anchor="middle" font-family="Inter, system-ui" font-size="11" fill="#3b82f6">record run_id · open SSE</text>
    </g>
    <line x1="360" y1="144" x2="360" y2="170" stroke="#6a6f78" stroke-width="1.4" marker-end="url(#arrow)" />

    <!-- PLANNER -->
    <g>
      <rect x="260" y="170" width="200" height="44" rx="8" fill="#ecfdf5" stroke="#059669" stroke-width="1.2"/>
      <text x="360" y="190" text-anchor="middle" font-family="Inter, system-ui" font-size="12" font-weight="600" fill="#047857">Planner LLM</text>
      <text x="360" y="206" text-anchor="middle" font-family="Inter, system-ui" font-size="11" fill="#059669">route to specialist</text>
    </g>
    <line x1="360" y1="214" x2="360" y2="240" stroke="#6a6f78" stroke-width="1.4" marker-end="url(#arrow)" />

    <!-- RESIDENT SPECIALIST -->
    <g>
      <rect x="220" y="240" width="280" height="48" rx="8" fill="#ecfdf5" stroke="#059669" stroke-width="1.2"/>
      <text x="360" y="261" text-anchor="middle" font-family="Inter, system-ui" font-size="12" font-weight="600" fill="#047857">research-librarian</text>
      <text x="360" y="278" text-anchor="middle" font-family="Inter, system-ui" font-size="10.5" fill="#059669">resident · decide work plan</text>
    </g>
    <line x1="360" y1="288" x2="360" y2="316" stroke="#059669" stroke-width="1.4" stroke-dasharray="3 3" marker-end="url(#arrow-brand)" />
    <text x="372" y="305" font-family="JetBrains Mono, monospace" font-size="9.5" fill="#059669">AgentSpec</text>

    <!-- SCOUT spec -->
    <g>
      <rect x="200" y="316" width="320" height="44" rx="8" fill="#fff7ed" stroke="#d97706" stroke-width="1.2" stroke-dasharray="0"/>
      <text x="360" y="336" text-anchor="middle" font-family="Inter, system-ui" font-size="12" font-weight="600" fill="#9a3412">AgentSpec[ literature-scout ]</text>
      <text x="360" y="351" text-anchor="middle" font-family="Inter, system-ui" font-size="10.5" fill="#d97706">search · 12 candidates</text>
    </g>

    <!-- Fanout: 3 readers -->
    <line x1="280" y1="360" x2="180" y2="395" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />
    <line x1="360" y1="360" x2="360" y2="395" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />
    <line x1="440" y1="360" x2="540" y2="395" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />

    <g>
      <rect x="90"  y="395" width="180" height="40" rx="8" fill="#fff7ed" stroke="#d97706" stroke-width="1.2"/>
      <text x="180" y="412" text-anchor="middle" font-family="Inter, system-ui" font-size="11.5" font-weight="600" fill="#9a3412">paper-reader</text>
      <text x="180" y="427" text-anchor="middle" font-family="Inter, system-ui" font-size="10" fill="#d97706">4 papers</text>
    </g>
    <g>
      <rect x="270" y="395" width="180" height="40" rx="8" fill="#fff7ed" stroke="#d97706" stroke-width="1.2"/>
      <text x="360" y="412" text-anchor="middle" font-family="Inter, system-ui" font-size="11.5" font-weight="600" fill="#9a3412">paper-reader</text>
      <text x="360" y="427" text-anchor="middle" font-family="Inter, system-ui" font-size="10" fill="#d97706">4 papers</text>
    </g>
    <g>
      <rect x="450" y="395" width="180" height="40" rx="8" fill="#fff7ed" stroke="#d97706" stroke-width="1.2"/>
      <text x="540" y="412" text-anchor="middle" font-family="Inter, system-ui" font-size="11.5" font-weight="600" fill="#9a3412">paper-reader</text>
      <text x="540" y="427" text-anchor="middle" font-family="Inter, system-ui" font-size="10" fill="#d97706">4 papers</text>
    </g>

    <line x1="180" y1="435" x2="320" y2="465" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />
    <line x1="360" y1="435" x2="360" y2="465" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />
    <line x1="540" y1="435" x2="400" y2="465" stroke="#6a6f78" stroke-width="1.2" marker-end="url(#arrow)" />

    <!-- Summarizer -->
    <g>
      <rect x="200" y="465" width="320" height="40" rx="8" fill="#f5f3ff" stroke="#7c3aed" stroke-width="1.2"/>
      <text x="360" y="482" text-anchor="middle" font-family="Inter, system-ui" font-size="12" font-weight="600" fill="#5b21b6">AgentSpec[ summarizer · deep ]</text>
      <text x="360" y="496" text-anchor="middle" font-family="Inter, system-ui" font-size="10.5" fill="#7c3aed">exo cluster</text>
    </g>

    <!-- Output -->
    <line x1="360" y1="505" x2="360" y2="525" stroke="#6a6f78" stroke-width="1.4" marker-end="url(#arrow)" />
    <text x="360" y="535" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#0f1115" font-weight="500">~/Desktop/agent-memory-2026-06-13.md</text>

    <!-- ACC / Budget on right -->
    <g>
      <rect x="565" y="232" width="135" height="44" rx="8" fill="#fef2f2" stroke="#e11d48" stroke-width="1.1" stroke-dasharray="2 2"/>
      <text x="632" y="252" text-anchor="middle" font-family="Inter, system-ui" font-size="11" font-weight="600" fill="#9f1239">ACC monitor</text>
      <text x="632" y="267" text-anchor="middle" font-family="Inter, system-ui" font-size="9.5" fill="#e11d48">watching streams</text>
    </g>
    <g>
      <rect x="565" y="290" width="135" height="44" rx="8" fill="#fef2f2" stroke="#e11d48" stroke-width="1.1" stroke-dasharray="2 2"/>
      <text x="632" y="310" text-anchor="middle" font-family="Inter, system-ui" font-size="11" font-weight="600" fill="#9f1239">Budget governor</text>
      <text x="632" y="325" text-anchor="middle" font-family="Inter, system-ui" font-size="9.5" fill="#e11d48">meter spend</text>
    </g>
  </svg>
</div>

<style>
  .graph-wrap {
    width: 100%;
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    background: var(--bg);
    overflow: hidden;
    box-shadow: var(--shadow-1);
  }
  .graph-wrap svg { display: block; width: 100%; height: auto; }
</style>

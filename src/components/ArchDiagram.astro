---
const planes = [
  {
    name: 'Surface',
    summary: 'Task panels on your devices. Where intents land and results return.',
    modules: 'CLI · HTTP + SSE · TUI (Bubble Tea)',
  },
  {
    name: 'Control',
    summary: 'One resident process — the brain. Planner, triage, DAG, budget, ACC.',
    modules: 'Planner LLM · Triage · DAG · Budget · ACC · Skills',
  },
  {
    name: 'Execution',
    summary: 'Ephemeral micro-agents in sandboxes. Two tools, ever.',
    modules: 'AgentSpec · Blackboard · Runner · search · execute',
  },
  {
    name: 'Compute',
    summary: 'Local inference. Optionally federated. OpenAI-compatible.',
    modules: 'LLM Router · Ollama · Cloud fallback · Offline echo',
  },
];

const edges = ['HTTP + SSE', 'AgentSpec', 'OpenAI-compat'];
---

<div class="arch">
  {planes.map((p, i) => (
    <>
      <div class="plane">
        <div class="plane-name">{p.name}</div>
        <div class="plane-body">
          <p class="plane-sum">{p.summary}</p>
          <p class="plane-mods">{p.modules}</p>
        </div>
      </div>
      {i < planes.length - 1 && (
        <div class="edge">
          <span class="edge-line"></span>
          <span class="edge-lbl">{edges[i]}</span>
          <span class="edge-line"></span>
        </div>
      )}
    </>
  ))}
</div>

<style>
  .arch {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--rule);
  }
  .plane {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--rule);
  }
  @media (min-width: 760px) {
    .plane { grid-template-columns: 180px 1fr; gap: 3rem; align-items: start; }
  }
  .plane-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--ink);
    font-weight: 500;
  }
  .plane-body { display: flex; flex-direction: column; gap: 0.45rem; }
  .plane-sum {
    margin: 0;
    color: var(--ink-2);
    font-size: 1rem;
  }
  .plane-mods {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-4);
  }
  .edge {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--rule);
    color: var(--ink-5);
  }
  .edge-line { flex: 1; height: 1px; background: var(--rule); }
  .edge-lbl {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ink-4);
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import LogStream from '../components/LogStream.astro';

const title = 'plnt — orchestration runtime for agentic workflows';
const description = 'Pick a workflow from the microagents registry, pick a GPU backend, and plnt handles the Helm deploy, canary, and rollback. Apache-2.0.';

const runStream = [
  { ts: '04:17:33', kind: 'pull',       payload: 'workflow=<span class="v">review-responder@1.2.0</span> · source=<span class="v">s3://microagents/</span>' },
  { ts: '04:17:34', kind: 'resolve',    payload: 'backend=<span class="v">gpu-cluster-01</span> · gpus=<span class="v">2× available</span> · region=<span class="v">us-east</span>' },
  { ts: '04:17:34', kind: 'workflow',   payload: 'temporal://plnt/orchestrate · run=<span class="v">r-9c4f218e0a</span>' },
  { ts: '04:17:35', kind: 'validate',   payload: 'spec ok · tool bindings ok · gpu class satisfied · image pullable' },
  { ts: '04:17:41', kind: 'helm',       payload: 'install release=<span class="v">review-responder-canary</span> · replicas=1 · traffic=5%' },
  { ts: '04:19:14', kind: 'smoke',      payload: '10 sample invocations · p50=<span class="v">1.1s</span> · errors=<span class="v">0</span> · pass' },
  { ts: '04:19:15', kind: 'promote',    payload: 'canary → stable · replicas=1→3 · traffic=100%' },
  { ts: '04:19:15', kind: 'ready',      payload: '<span class="v">https://review-responder.plnt.svc/invoke</span>' },
];

const repos = [
  {
    key: 'google-business',
    tag: 'PRODUCT',
    desc: 'AI copilot for Google Business Profile owners. Auto-reply to reviews, generate weekly posts, triage booking inquiries, publish updates.',
    role: 'The end-user product. Pulls its workflows from microagents; runs them on plnt.',
    href: 'https://github.com/plnt-work/google-business',
  },
  {
    key: 'microagents',
    tag: 'REGISTRY',
    desc: 'Pluggable agentic workflows. Each one ships as a spec + code, versioned and pullable over S3. Think npm, but for agent recipes.',
    role: 'The workflow layer. Anyone can publish; anyone can pull. Fully open.',
    href: 'https://github.com/plnt-work/microagents',
  },
  {
    key: 'plnt',
    tag: 'RUNTIME',
    desc: 'Given a workflow spec + a Kubernetes backend, plnt orchestrates the run: Helm deploy, canary, smoke test, promote or rollback, all as a Temporal saga.',
    role: 'The infra load-bearing piece. This is the deep repo.',
    href: 'https://github.com/plnt-work/plnt',
  },
];

const features = [
  {
    icon: '01',
    title: 'Workflow-first',
    body: 'Point plnt at a workflow spec pulled from any OCI or S3 registry. Steps, tool bindings, GPU class, replicas — all declared, not scripted.',
  },
  {
    icon: '02',
    title: 'Backend-agnostic',
    body: 'Any Kubernetes cluster with GPU nodes. Same YAML runs on kind, GKE, EKS, on-prem. Pick the backend at deploy time.',
  },
  {
    icon: '03',
    title: 'Canary by default',
    body: 'Every run is a canary first. 5% traffic → smoke test → promote. Fails fast, rolls back cleanly. Compensation via Temporal, not bash scripts.',
  },
  {
    icon: '04',
    title: 'Durable saga',
    body: 'Every deploy is a Temporal workflow. Process restarts resume from the last completed step. Nothing hides in bash state or in-memory queues.',
  },
  {
    icon: '05',
    title: 'Multi-GPU aware',
    body: 'Workflows declare GPU class + count. plnt schedules across node pools, respects nvidia.com/gpu limits, streams GPU utilization back to the caller.',
  },
  {
    icon: '06',
    title: 'One CRD, one contract',
    body: 'A single WorkflowRun CRD is the entire deploy trigger. kubectl apply. The operator does the rest.',
  },
];

const steps = [
  { n: '01', title: 'Pull', body: 'Fetch a workflow spec from microagents (or any S3/OCI registry). Verified by hash, pinned by version.' },
  { n: '02', title: 'Orchestrate', body: 'plnt starts a Temporal saga: validate → helm install canary → smoke → promote or rollback. Durable, resumable, inspectable.' },
  { n: '03', title: 'Serve', body: 'Workflow is reachable at <code>&lt;name&gt;.plnt.svc/invoke</code>. Uniform request shape across every workflow.' },
];
---

<Layout title={title} description={description} path="/">

  <section class="hero">
    <div class="container">
      <span class="chip solid"><span class="dot">Y</span> Open source · Apache-2.0</span>
      <h1 class="mt-4" style="max-width: 20ch;">
        Ship agentic workflows to <span class="grad">any GPU backend</span>.
      </h1>
      <p class="lead mt-4" style="max-width: 60ch;">
        plnt is the orchestration runtime for micro-agent workflows.
        Pick a workflow from the registry, pick a Kubernetes GPU cluster,
        and plnt handles the Helm deploy, canary, and rollback — as a durable Temporal saga.
      </p>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="https://play.plnt.work" target="_blank" rel="noopener">
          Open playground <span class="arrow">→</span>
        </a>
        <a class="btn" href="/architecture">Read architecture</a>
        <a class="btn ghost" href="https://github.com/plnt-work/plnt" target="_blank" rel="noopener">GitHub ↗</a>
      </div>

      <div class="mt-6" style="max-width: 820px;">
        <div class="term">
          <div class="chrome">
            <span class="dots"><span></span><span></span><span></span></span>
            <span>plnt run review-responder</span>
          </div>
          <div class="body">
            <div style="margin-bottom: 0.75rem;">
              <span class="prompt">$</span> plnt run review-responder@1.2.0 --backend gpu-cluster-01
            </div>
            <LogStream events={runStream} />
          </div>
        </div>
      </div>

      <div class="mt-6 metric-strip">
        <div class="m"><div class="k">Runtime</div><div class="v">Temporal saga</div><div class="sub">durable · resumable</div></div>
        <div class="m"><div class="k">Registry</div><div class="v">S3 / OCI</div><div class="sub">version pinned</div></div>
        <div class="m"><div class="k">Backend</div><div class="v">Any K8s + GPU</div><div class="sub">kind → prod</div></div>
        <div class="m"><div class="k">Deploy</div><div class="v">Helm + canary</div><div class="sub">5% → smoke → 100%</div></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 05</span> — THE STACK</div>
        <div>
          <p class="lead-text">
            <strong>Three repos, one story.</strong>
            An end-user product that needs narrow, reliable AI features.
            A public registry of workflow recipes anyone can pull.
            A runtime that turns any Kubernetes cluster into a place those recipes can run.
          </p>
        </div>
      </div>

      <div class="grid-3">
        {repos.map((r) => (
          <a class="card" href={r.href} target="_blank" rel="noopener" style="text-decoration:none; color:inherit;">
            <div class="card-icon">{r.tag[0]}</div>
            <div style="font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--ink-5); margin-bottom: 0.35rem;">{r.tag}</div>
            <h3>{r.key}</h3>
            <p>{r.desc}</p>
            <p style="margin-top: 0.75rem; color: var(--ink-5); font-size: 0.82rem;">{r.role}</p>
            <span class="card-link">View repo <span class="arrow">↗</span></span>
          </a>
        ))}
      </div>

      <div class="term mt-6" style="max-width: 940px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>architecture · top-down</span>
        </div>
        <div class="body">
<pre style="font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.65; color: var(--ink-3); margin: 0;">    ┌────────────────────────────────────┐
    │  google-business   (end-user SaaS)   │  reviews · posts · bookings
    └───────────────────┬────────────────┘
                        │  invokes
                        ▼
    ┌────────────────────────────────────┐
    │  microagents  (workflow registry)  │  pluggable recipes on S3
    │  review-responder · post-generator │
    │  booking-triage  · trend-monitor   │
    └───────────────────┬────────────────┘
                        │  pulls spec
                        ▼
    ┌────────────────────────────────────┐
    │  plnt  (orchestration runtime)     │  ← this repo
    │  WorkflowRun CRD · Temporal saga   │
    │  Helm install · canary · rollback  │
    └───────────────────┬────────────────┘
                        │  helm install
                        ▼
    ┌────────────────────────────────────┐
    │  Kubernetes GPU backends           │  kind · GKE · EKS · on-prem
    │  scheduler · nvidia.com/gpu        │
    └────────────────────────────────────┘</pre>
        </div>
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 05</span> — WHAT PLNT DOES</div>
        <div>
          <p class="lead-text">
            <strong>Six primitives.</strong> Enough to turn a workflow spec into
            a running service on a GPU cluster, without hand-rolled scripts.
          </p>
        </div>
      </div>
      <div class="grid-3">
        {features.map((f) => (
          <div class="card">
            <div class="card-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 05</span> — HOW</div>
        <div>
          <p class="lead-text">
            Three steps. No control plane to run. No deploy scripts to maintain.
            The Kubernetes and Temporal primitives do the work.
          </p>
        </div>
      </div>
      <div class="steps-list">
        {steps.map((s) => (
          <div class="li">
            <div class="n">{s.n}</div>
            <div class="body">
              <strong>{s.title}</strong>
              <p set:html={s.body} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 05</span> — RUN ONE</div>
        <div>
          <p class="lead-text">
            One CRD. One Helm install. One <code>curl</code>.
          </p>
        </div>
      </div>
      <div class="grid-2">
        <div class="term">
          <div class="chrome">
            <span class="dots"><span></span><span></span><span></span></span>
            <span>examples/review-responder.yaml</span>
          </div>
          <div class="body">
<pre style="margin:0; color: var(--ink-2);">apiVersion: plnt.work/v1
kind: WorkflowRun
metadata:
  name: review-responder
spec:
  workflow:
    ref: review-responder@1.2.0
    registry: s3://microagents
  backend:
    cluster: gpu-cluster-01
    gpuClass: nvidia.com/h100
    gpuCount: 2
  replicas:
    min: 1
    max: 4
  canary:
    trafficPercent: 5
    smokeTest:
      invocations: 10
      p95BudgetMs: 2500</pre>
          </div>
        </div>

        <div class="term">
          <div class="chrome">
            <span class="dots"><span></span><span></span><span></span></span>
            <span>plnt · deploy from kubectl</span>
          </div>
          <div class="body">
            <div><span class="cmt"># apply the WorkflowRun resource</span></div>
            <div><span class="prompt">$</span> kubectl apply -f review-responder.yaml</div>
            <div style="margin-top: 0.75rem;"><span class="cmt"># plnt operator picks it up and starts the saga</span></div>
            <div><span class="prompt">$</span> plnt logs review-responder --follow</div>
            <div style="margin-top: 0.75rem;"><span class="cmt"># invoke it</span></div>
            <div><span class="prompt">$</span> curl -s https://review-responder.plnt.svc/invoke \</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;-H <span class="str">"content-type: application/json"</span> \</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;-d <span class="str">{`'{"review":{"rating":2,"text":"..."}}'`}</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: clamp(4rem, 8vw, 6rem); padding-bottom: clamp(4rem, 8vw, 6rem);">
    <div class="container">
      <div class="sechead">
        <div class="count">05 <span class="of">/ 05</span> — GET STARTED</div>
        <div>
          <p class="lead-text">
            The playground runs live. The repos are open.
            The docs walk through a 60-second kind demo.
          </p>
        </div>
      </div>
      <div class="flex gap wrap">
        <a class="btn primary" href="https://play.plnt.work" target="_blank" rel="noopener">
          Open playground <span class="arrow">→</span>
        </a>
        <a class="btn" href="/docs/">Read the docs</a>
        <a class="btn" href="/architecture">Architecture</a>
        <a class="btn ghost" href="https://github.com/plnt-work/plnt" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

</Layout>

---
import Layout from '../layouts/Layout.astro';
import ArchDiagram from '../components/ArchDiagram.astro';
import SpawnGraph from '../components/SpawnGraph.astro';
import LogStream from '../components/LogStream.astro';

const title = 'plnt — a local-first agent runtime';
const description = 'plnt is an open-source personal agent runtime. One resident planner spawns a swarm of sandboxed micro-agents on your own hardware. Memory is plain files. Apache-2.0.';

const liveEvents = [
  { ts: '04:17:33', kind: 'intent', payload: '<span class="v">"papers by 7am"</span>' },
  { ts: '04:17:33', kind: 'plan', payload: '<span class="k">agents</span>: 4 · librarian → readers → summarizer' },
  { ts: '04:17:34', kind: 'spawn', payload: 'literature-scout · isolation=process' },
  { ts: '04:17:36', kind: 'tool_call', payload: 'search("agent memory", "~/Documents")' },
  { ts: '04:17:36', kind: 'tool_result', payload: '<span class="v">12 candidates</span>' },
  { ts: '04:18:42', kind: 'model_call', payload: 'summarizer · deep · exo' },
  { ts: '04:19:02', kind: 'finished', payload: '<span class="v">12 papers · 12 min · $0</span>' },
];

const choices = [
  { k: 'Resident + ephemeral', v: '<strong>Resident planner and named specialists, ephemeral spawns.</strong> Long-lived specialists with shared state outperform many-ephemeral (HearthNet).' },
  { k: 'Filesystem memory', v: '<strong>JSONL + markdown + FAISS sidecar.</strong> No schema before the data has shape. <code>cat</code> / <code>grep</code> / <code>jq</code> / <code>git</code> is the admin UI.' },
  { k: 'Two tools', v: '<strong>search and execute.</strong> The RLM pattern. Context lives in the filesystem; anything else is reachable through these.' },
  { k: 'Sandbox ladder', v: '<strong>process → gVisor → µVM → wasm.</strong> Climb only when the threat model demands. Docker is not enough for LLM-emitted code.' },
  { k: 'Federate compute', v: '<strong>Compute federated, agents not (exo style).</strong> Multi-device inference is solved; multi-device agent state is a debugging hellscape.' },
  { k: 'No MCP, no SaaS', v: '<strong>The framework owns memory, skills, and the sandbox.</strong> The model is a swappable backend.' },
];
---

<Layout title={title} description={description} path="/">

  <section class="section" style="padding-top: clamp(5rem, 10vw, 8rem); padding-bottom: clamp(4rem, 7vw, 6rem);">
    <div class="container">
      <span class="eyebrow">00 / 06 — plnt</span>
      <h1 style="max-width: 22ch;">A local-first agent runtime that runs on your hardware.</h1>
      <p class="lead mt-4" style="max-width: 56ch;">
        One resident planner spawns a swarm of sandboxed micro-agents.
        Memory is plain files. <code>cat</code>, <code>grep</code>, <code>jq</code>, <code>git</code>
        are the admin tools. No cloud bill, no vendor SDK, no SaaS that disappears when funding does.
      </p>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="/docs/getting-started/install/">Install <span class="arrow">→</span></a>
        <a class="btn" href="/architecture">Architecture</a>
        <a class="btn" href="https://github.com/devdattatalele/plnt" target="_blank" rel="noopener">GitHub</a>
      </div>

      <div class="mt-6" style="max-width: 720px;">
        <div class="term">
          <div class="chrome">
            <span class="dots"><span></span><span></span><span></span></span>
            <span>~/.plnt/runs/r-9c4f218e0a</span>
          </div>
          <div class="body">
            <div style="margin-bottom: 0.85rem;">
              <span class="prompt">$</span> plnt submit <span class="str">"catch me up on agent memory papers by 7am"</span>
            </div>
            <LogStream events={liveEvents} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 06</span> — WHAT</div>
        <h2 class="lead-text" style="font-size: clamp(1.5rem, 2.6vw, 2rem); font-weight: 500; letter-spacing: -0.02em; line-height: 1.25;">
          <strong>plnt is the anti-SaaS personal agent platform.</strong> Four planes
          with hard responsibility boundaries. The only object that crosses
          <strong>Control → Execution</strong> is the <code>AgentSpec</code>.
        </h2>
      </div>
      <ArchDiagram />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 06</span> — HOW</div>
        <p class="lead-text">
          Three steps. No daemons to babysit. No accounts to provision. No deploys
          to coordinate. The offline echo backend means it runs with no LLM at all.
        </p>
      </div>
      <div class="steps-list">
        <div class="li">
          <div class="n">01</div>
          <div class="body">
            <strong>Install</strong>
            <p><code>git clone</code> the repo. <code>pip install -e .</code>. Optionally point at a local Ollama. The offline echo backend exercises the full pipeline with no LLM.</p>
          </div>
        </div>
        <div class="li">
          <div class="n">02</div>
          <div class="body">
            <strong>Submit</strong>
            <p><code>plnt submit "find anything on agent memory in my Documents"</code>. The planner triages, plans a DAG, and spawns ephemeral micro-agents in sandboxes.</p>
          </div>
        </div>
        <div class="li">
          <div class="n">03</div>
          <div class="body">
            <strong>Tail</strong>
            <p>Every event lands in <code>events.jsonl</code> as it happens. The result is a markdown file in <code>~/Desktop</code>. The audit log is one <code>cat</code> away.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 06</span> — FLOW</div>
        <p class="lead-text">
          A single intent traverses the system. Resident specialists decide work plans.
          Ephemeral micro-agents do the legwork. <strong>Nothing leaves your hardware.</strong>
        </p>
      </div>
      <SpawnGraph />
      <p class="dim mt-4" style="font-family: var(--font-mono); font-size: 0.78rem; text-align: center;">
        12 papers · 12 minutes wall-clock · $0 cloud spend · 0 bytes left your box
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 06</span> — CHOICES</div>
        <p class="lead-text">
          Six decisions that shape everything. Each is a hill the project will die on.
          The right column is the receipt.
        </p>
      </div>
      <div class="rows">
        {choices.map((c) => (
          <div class="r">
            <div class="k">{c.k}</div>
            <p class="v" set:html={c.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">05 <span class="of">/ 06</span> — OSS</div>
        <p class="lead-text">
          <strong>Apache 2.0.</strong> ~4,800 lines of Python plus a Go TUI client. No telemetry.
          No analytics. No opt-in usage data. What you run is what you can read.
          We hold three things on the roadmap and refuse to change them — no database,
          no HTTP bus between planner and specialists, no MCP.
        </p>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: clamp(5rem, 9vw, 8rem); padding-bottom: clamp(5rem, 9vw, 8rem);">
    <div class="container">
      <div class="sechead">
        <div class="count">06 <span class="of">/ 06</span> — INSTALL</div>
        <p class="lead-text">
          Two commands. Five minutes. No accounts.
        </p>
      </div>
      <div class="term" style="max-width: 720px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>install · plnt — bash</span>
        </div>
        <div class="body">
          <div><span class="cmt"># clone + install</span></div>
          <div><span class="prompt">$</span> git clone https://github.com/devdattatalele/plnt</div>
          <div><span class="prompt">$</span> cd plnt && pip install -e <span class="str">"."</span></div>
          <div style="margin-top: 0.85rem;"><span class="cmt"># submit (offline echo works with no LLM)</span></div>
          <div><span class="prompt">$</span> plnt submit <span class="str">"list five interesting things in $PWD"</span></div>
          <div style="margin-top: 0.85rem;"><span class="cmt"># server + TUI</span></div>
          <div><span class="prompt">$</span> plnt up &</div>
          <div><span class="prompt">$</span> ./plnt-tui-bin</div>
        </div>
      </div>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="/docs/getting-started/install/">Install <span class="arrow">→</span></a>
        <a class="btn" href="/docs/">Read the docs</a>
        <a class="btn" href="https://github.com/devdattatalele/plnt" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

</Layout>

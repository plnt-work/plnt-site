---
import Layout from '../layouts/Layout.astro';

const title = 'Roadmap — plnt';
const description = 'What ships in v0, the 12-week plan to v0.1, the punch list, and the architectural choices being held.';

const v0Ships = [
  { name: 'Surface', detail: 'REST + SSE. mTLS stub (loopback only).' },
  { name: 'Control', detail: 'Keyword-routed planner with LLM plug-in shape.' },
  { name: 'Execution', detail: 'Process + docker sandbox rungs. Full event stream.' },
  { name: 'Compute', detail: 'OpenAI-compatible router with offline-echo fallback.' },
  { name: 'Memory', detail: 'Per-run JSONL + artifacts. Episodic dir scaffolded.' },
  { name: 'Skills', detail: '8 seed bundles. Hot-reload. Installer for anthropic/skills + 4 others.' },
  { name: 'TUI', detail: 'Go / Bubble Tea client. Chat history. SSE event routing.' },
  { name: 'Tests', detail: '31 / 31 green. Offline echo means no LLM required.' },
];

const weeks12 = [
  { week: '1–2',   item: 'Surface + mTLS',                 done: false },
  { week: '3–4',   item: 'Control plane + rung-0 sandbox', done: true },
  { week: '5',     item: 'ACC + budget governance',        done: true },
  { week: '6–7',   item: 'Five seed skills',               done: true },
  { week: '8',     item: 'exo router',                     done: false },
  { week: '9–10',  item: 'iOS client',                     done: false },
  { week: '11',    item: 'Dashboard',                      done: false },
  { week: '12',    item: 'Private beta',                   done: false },
];

const punchList = [
  { title: 'Resident planner service', detail: 'Today the orchestrator materialises a planner per intent. Target: a long-lived process holding identity + warm state across days.' },
  { title: 'Streaming ACC + budget tail', detail: 'Today the ACC runs post-hoc. Make runaway kills fire in real time.' },
  { title: 'Resident specialist runtime', detail: 'Pool of pre-warmed processes per named role, vs. ephemeral spawns.' },
  { title: 'Episodic memory append', detail: 'One JSONL line per completed run to $PLNT_HOME/episodic/YYYY/MM/DD.jsonl.' },
  { title: 'mTLS + plnt enroll', detail: 'Make "your phone reaches the server" real. Today loopback only.' },
  { title: 'De-duplicate finished events', detail: 'Three finished events fire at end of run. Consolidate to one.' },
];

const heldNonChanges = [
  'No database. The filesystem is the memory.',
  'No HTTP bus between planner and specialists. Function calls + in-process queues.',
  'No MCP. The framework owns memory, skills, and the sandbox.',
];
---

<Layout title={title} description={description} path="/roadmap">

  <section class="section" style="padding-top: clamp(3.5rem, 6vw, 5rem); padding-bottom: clamp(2rem, 4vw, 3rem);">
    <div class="container narrow center">
      <span class="eyebrow">roadmap</span>
      <h1>v0 ships today.<br/>v0.1 is the next 12 weeks.</h1>
      <p class="lead dim" style="margin: 1.25rem auto 0; max-width: 56ch;">
        plnt is pre-alpha. The four planes work end-to-end. The pieces explicitly stubbed,
        and the architectural choices being held, are documented below.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">shipping today · v0</span>
      <h2>What works end-to-end right now.</h2>
      <div class="grid-2 mt-4">
        {v0Ships.map((s) => (
          <div class="card">
            <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem;">
              <span style="display: inline-flex; width: 18px; height: 18px; border-radius: 50%; background: var(--brand-tint); color: var(--brand-1); align-items: center; justify-content: center;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
              </span>
              <h3 style="margin: 0;">{s.name}</h3>
            </div>
            <p style="margin: 0; color: var(--ink-3);">{s.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container">
      <span class="eyebrow">12-week plan</span>
      <h2>Path to v0.1.</h2>
      <p class="lead dim">From the design doc. Eight pieces, in priority order.</p>

      <div class="timeline mt-4">
        {weeks12.map((w) => (
          <div class={`tl-row ${w.done ? 'done' : ''}`}>
            <div class="tl-week">Week {w.week}</div>
            <div class="tl-dot"></div>
            <div class="tl-item">
              <strong>{w.item}</strong>
              {w.done && <span class="pill brand compact" style="margin-left: 0.5rem;">shipped</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">v0 → v0.1 punch list</span>
      <h2>Six concrete changes.</h2>
      <p class="lead dim">Tracked in <code>IMPROVEMENTS.md</code>. Each item is a scoped change against the working v0.</p>

      <div class="grid-2 mt-4">
        {punchList.map((p, i) => (
          <div class="card">
            <span class="tag">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.title}</h3>
            <p>{p.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container narrow">
      <span class="eyebrow">held — explicit non-changes</span>
      <h2>Three things we will not add.</h2>
      <p class="lead dim">Architectural choices being held. Adding any of these would invert the project.</p>

      <div class="mt-4" style="display: flex; flex-direction: column; gap: 0.85rem;">
        {heldNonChanges.map((line) => (
          <div class="card" style="display: flex; gap: 0.75rem; align-items: flex-start;">
            <span style="display: inline-flex; width: 22px; height: 22px; flex: none; border-radius: 6px; background: #fee2e2; color: #b91c1c; align-items: center; justify-content: center; margin-top: 0.1rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </span>
            <div>{line}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow center">
      <span class="eyebrow">references</span>
      <p class="dim">
        Beyond Scaling (arXiv:<a href="https://arxiv.org/abs/2605.18535" target="_blank" rel="noopener">2605.18535</a>) ·
        HearthNet (arXiv:<a href="https://arxiv.org/abs/2604.09618" target="_blank" rel="noopener">2604.09618</a>) ·
        <a href="https://github.com/exo-explore/exo" target="_blank" rel="noopener">exo</a> distributed inference ·
        Agentnetes · Firecracker / gVisor sandbox consensus 2026.
      </p>
    </div>
  </section>

</Layout>

<style>
  .timeline {
    position: relative;
    padding-left: 0;
  }
  .tl-row {
    display: grid;
    grid-template-columns: 100px 24px 1fr;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--rule);
  }
  .tl-row:last-child { border-bottom: 1px solid var(--rule); }
  .tl-week {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ink-4);
  }
  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--ink-5);
    background: var(--bg-elev);
    justify-self: center;
  }
  .tl-row.done .tl-dot { background: var(--brand); border-color: var(--brand); }
  .tl-item { color: var(--ink-2); font-size: 0.9375rem; }
  .tl-item strong { color: var(--ink); font-weight: 600; }
  :global(.pill.compact) { font-size: 0.7rem !important; padding: 0.1rem 0.45rem; }
</style>

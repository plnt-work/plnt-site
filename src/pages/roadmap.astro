---
import Layout from '../layouts/Layout.astro';

const title = 'Roadmap — plnt';
const description = 'What ships in v0, the 12-week plan to v0.1, the punch list, and the architectural choices being held.';

const v0Ships = [
  { k: 'Surface', v: 'REST + SSE. mTLS stub (loopback only).' },
  { k: 'Control', v: 'Keyword-routed planner with LLM plug-in shape.' },
  { k: 'Execution', v: 'Process + docker sandbox rungs. Full event stream.' },
  { k: 'Compute', v: 'OpenAI-compatible router with offline-echo fallback.' },
  { k: 'Memory', v: 'Per-run JSONL + artifacts. Episodic dir scaffolded.' },
  { k: 'Skills', v: '8 seed bundles. Hot-reload. Installer for anthropic/skills + 4 others.' },
  { k: 'TUI', v: 'Go / Bubble Tea client. Chat history. SSE event routing.' },
  { k: 'Tests', v: '31 / 31 green. Offline echo means no LLM required.' },
];

const weeks12 = [
  { w: 'Weeks 01 — 02', label: 'Surface + mTLS', done: false },
  { w: 'Weeks 03 — 04', label: 'Control plane + rung-0 sandbox', done: true },
  { w: 'Week 05',       label: 'ACC + budget governance', done: true },
  { w: 'Weeks 06 — 07', label: 'Five seed skills', done: true },
  { w: 'Week 08',       label: 'exo router', done: false },
  { w: 'Weeks 09 — 10', label: 'iOS client', done: false },
  { w: 'Week 11',       label: 'Dashboard', done: false },
  { w: 'Week 12',       label: 'Private beta', done: false },
];

const punchList = [
  { title: 'Resident planner service', detail: 'Today the orchestrator materialises a planner per intent. Target: a long-lived process holding identity + warm state across days.' },
  { title: 'Streaming ACC + budget tail', detail: 'Today the ACC runs post-hoc. Make runaway kills fire in real time.' },
  { title: 'Resident specialist runtime', detail: 'Pool of pre-warmed processes per named role, vs. ephemeral spawns.' },
  { title: 'Episodic memory append', detail: 'One JSONL line per completed run to <code>$PLNT_HOME/episodic/YYYY/MM/DD.jsonl</code>.' },
  { title: 'mTLS + plnt enroll', detail: 'Make "your phone reaches the server" real. Today loopback only.' },
  { title: 'De-duplicate finished events', detail: 'Three finished events fire at end of run. Consolidate to one.' },
];

const heldNonChanges = [
  '<strong>No database.</strong> The filesystem is the memory.',
  '<strong>No HTTP bus between planner and specialists.</strong> Function calls + in-process queues.',
  '<strong>No MCP.</strong> The framework owns memory, skills, and the sandbox.',
];
---

<Layout title={title} description={description} path="/roadmap">

  <section class="section" style="padding-top: clamp(5rem, 9vw, 7rem); padding-bottom: clamp(4rem, 6vw, 5rem);">
    <div class="container">
      <span class="eyebrow">00 / 04 — roadmap</span>
      <h1 style="max-width: 22ch;">v0 ships today. v0.1 is the next twelve weeks.</h1>
      <p class="lead mt-4" style="max-width: 60ch;">
        plnt is pre-alpha. The four planes work end-to-end. The pieces explicitly
        stubbed, and the architectural choices being held, are documented here.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 04</span> — SHIPPING</div>
        <p class="lead-text">What works end-to-end right now in v0.</p>
      </div>
      <div class="rows">
        {v0Ships.map((s) => (
          <div class="r">
            <div class="k">{s.k}</div>
            <p class="v" set:html={s.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 04</span> — 12 WEEKS</div>
        <p class="lead-text">Path to v0.1. Eight pieces, in priority order.</p>
      </div>
      <div class="steps-list">
        {weeks12.map((w) => (
          <div class="li">
            <div class="n" style={w.done ? 'color: var(--acc);' : 'color: var(--ink-4);'}>{w.done ? '◉' : '○'}</div>
            <div class="body">
              <strong>{w.label}</strong>
              <p style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.14em;">{w.w}{w.done ? ' · shipped' : ''}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 04</span> — PUNCH LIST</div>
        <p class="lead-text">
          v0 → v0.1. Tracked in <code>IMPROVEMENTS.md</code>. Six concrete scoped changes.
        </p>
      </div>
      <div class="steps-list">
        {punchList.map((p, i) => (
          <div class="li">
            <div class="n">{String(i + 1).padStart(2, '0')}</div>
            <div class="body">
              <strong>{p.title}</strong>
              <p set:html={p.detail} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 04</span> — HELD</div>
        <p class="lead-text">
          Three architectural choices being held. Adding any of them would invert the project.
        </p>
      </div>
      <div class="rows">
        {heldNonChanges.map((line) => (
          <div class="r">
            <div class="k">NO</div>
            <p class="v" set:html={line} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="dim" style="font-size: 0.875rem; max-width: 60ch;">
        Influences ·
        Beyond Scaling (arXiv:<a href="https://arxiv.org/abs/2605.18535" target="_blank" rel="noopener">2605.18535</a>) ·
        HearthNet (arXiv:<a href="https://arxiv.org/abs/2604.09618" target="_blank" rel="noopener">2604.09618</a>) ·
        <a href="https://github.com/exo-explore/exo" target="_blank" rel="noopener">exo</a> ·
        Agentnetes · Firecracker / gVisor consensus 2026.
      </p>
    </div>
  </section>

</Layout>

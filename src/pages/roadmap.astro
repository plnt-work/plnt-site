---
import Layout from '../layouts/Layout.astro';

const title = 'Roadmap — plnt';
const description = 'What ships today. What Phases 1–6 add. What we explicitly refuse to do.';

const shipping = [
  { k: 'WorkflowRun CRD',   v: 'Schema + printer columns + status subresource. <code>kubectl apply -f workflow.yaml</code> is the entire deploy trigger. Installed by the plnt Helm chart.' },
  { k: 'Operator (kopf)',   v: '<code>plnt/operators/workflowrun_controller.py</code> watches create/update/delete → starts or cancels a Temporal orchestration workflow.' },
  { k: 'Orchestration saga', v: '<code>plnt/workflows/orchestrate.py</code> — five-step Temporal workflow (pull → resolve → helm → smoke → promote or rollback) with per-activity retries + compensation.' },
  { k: 'Helm chart template', v: '<code>plnt/charts/workflow-runner/</code> — Deployment + Service + Ingress + HPA + ConfigMap. Parameterised over workflow ref, backend, GPU class, replicas.' },
  { k: 'Playground API',    v: 'FastAPI wrapper exposing the workflow catalog + invoke path. OpenAI-compatible endpoint kept for the demo chat surface.' },
  { k: 'Live playground',   v: '<a href="https://play.plnt.work">play.plnt.work</a> — browser UI showing the workflow orchestration timeline + backend selector + invocation log.' },
  { k: 'Marketing site',    v: '<a href="https://plnt.work">plnt.work</a> — this. Static Astro build on Vercel. Architecture, roadmap, docs, resources.' },
];

const phases = [
  {
    n: '00',
    label: 'Skeleton + narrative',
    status: 'shipped',
    detail: 'Repo layout for <code>charts/</code>, <code>operators/</code>, <code>workflows/</code>, <code>cli/</code>, <code>registry/</code>. README + <code>docs/architecture.md</code> written around the 4-layer stack.',
  },
  {
    n: '01',
    label: 'Workflow runner Helm chart',
    status: 'in progress',
    detail: '<code>plnt/charts/workflow-runner/</code> — parameterised Deployment for any workflow spec pulled from microagents. Installable on kind today; ready to drop onto a real GPU node pool.',
  },
  {
    n: '02',
    label: 'Temporal orchestration saga',
    status: 'in progress',
    detail: '<code>plnt/workflows/orchestrate.py</code> — pull → resolve backend → helm install canary → smoke → promote saga. <code>RetryPolicy</code> per activity. <code>helm rollback</code> as compensation.',
  },
  {
    n: '03',
    label: 'WorkflowRun CRD + operator',
    status: 'planned',
    detail: 'CRD spec at <code>plnt/operators/crds/workflowrun.yaml</code>. Python <code>kopf</code> operator watches the CRD and drives the Temporal saga. <code>kubectl apply</code> is the only entrypoint.',
  },
  {
    n: '04',
    label: 'plnt CLI',
    status: 'planned',
    detail: '<code>plnt run</code>, <code>plnt list</code>, <code>plnt scale</code>, <code>plnt rollback</code>, <code>plnt bench</code>. <code>typer</code>-based; wraps <code>kubectl</code> + <code>helm</code> + Temporal client. Typed with pydantic.',
  },
  {
    n: '05',
    label: 'Multi-backend scheduling',
    status: 'planned',
    detail: '<code>PlntBackend</code> resource — register a named backend once, reference it from every WorkflowRun. Capacity-aware placement (queue depth + GPU headroom) across pools inside one cluster.',
  },
  {
    n: '06',
    label: 'Benchmarking + dashboard',
    status: 'planned',
    detail: '<code>plnt/bench/harness.py</code> measures p50/p95/p99 per-invocation latency, error rate, GPU utilization, step-cache hit rate. Prometheus scrape config in the chart. One Grafana dashboard JSON committed.',
  },
];

const held = [
  { k: 'NO', v: '<strong>No proprietary workflow format.</strong> The <code>microagents</code> spec is public, versioned, and hash-verifiable. Any registry that speaks S3 or OCI works.' },
  { k: 'NO', v: '<strong>No custom deploy scripts.</strong> The saga is a Temporal workflow, not a bash pipeline. State is durable, resumable, inspectable.' },
  { k: 'NO', v: '<strong>No cloud lock-in.</strong> Helm + Kubernetes + Temporal are portable. Same WorkflowRun YAML runs on kind, GKE, EKS, AKS, on-prem.' },
  { k: 'NO', v: '<strong>No mystery orchestration.</strong> The operator is small enough to read in one sitting. Every state transition emits a Kubernetes event.' },
];
---

<Layout title={title} description={description} path="/roadmap">

  <section class="hero" style="padding-top: clamp(3.5rem, 6vw, 5rem); padding-bottom: clamp(2.5rem, 4vw, 3.5rem);">
    <div class="container">
      <span class="eyebrow">00 / 04 — roadmap</span>
      <h1 style="max-width: 22ch;">The runtime in seven phases.</h1>
      <p class="lead mt-4" style="max-width: 60ch;">
        Phase 0 shipped. Phases 1–2 in progress. Phases 3–6 are scoped and sequenced.
        Progress tracked in the plnt repo.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 04</span> — SHIPPING</div>
        <div><p class="lead-text">What works end-to-end right now.</p></div>
      </div>
      <div class="rows">
        {shipping.map((s) => (
          <div class="r">
            <div class="k">{s.k}</div>
            <p class="v" set:html={s.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 04</span> — PHASES</div>
        <div><p class="lead-text">Seven phases from skeleton to a benchmarked, canary-deployed, multi-backend runtime.</p></div>
      </div>
      <div class="steps-list">
        {phases.map((p) => {
          const color = p.status === 'shipped' ? 'var(--acc)' : p.status === 'in progress' ? 'var(--ink)' : 'var(--ink-5)';
          const marker = p.status === 'shipped' ? '●' : p.status === 'in progress' ? '◐' : '○';
          return (
            <div class="li">
              <div class="n" style={`color: ${color};`}>{marker}</div>
              <div class="body">
                <strong>{p.label}</strong>
                <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-5); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 0.5rem;">
                  Phase {p.n} · {p.status}
                </p>
                <p set:html={p.detail} />
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 04</span> — HELD</div>
        <div><p class="lead-text">Four architectural choices being held. Reversing any of them would invert the project.</p></div>
      </div>
      <div class="rows">
        {held.map((h) => (
          <div class="r">
            <div class="k">{h.k}</div>
            <p class="v" set:html={h.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 04</span> — INFLUENCES</div>
        <div><p class="lead-text">Prior art that shapes the design.</p></div>
      </div>
      <p class="dim" style="font-size: 0.92rem; max-width: 68ch;">
        Google SRE (cascading failures chapter) ·
        Temporal (deploy sagas, activity retries, compensation) ·
        <a href="https://kserve.github.io/website/" target="_blank" rel="noopener">KServe</a> (CRD shape for inference workloads) ·
        <a href="https://argoproj.github.io/argo-workflows/" target="_blank" rel="noopener">Argo Workflows</a> (DAG-of-steps model, K8s-native) ·
        <a href="https://numaproj.io/" target="_blank" rel="noopener">Numaflow</a> (stream-processing DAG on K8s) ·
        Helm (chart-per-runner packaging) ·
        Envoy VirtualService (canary weights).
      </p>
    </div>
  </section>

</Layout>

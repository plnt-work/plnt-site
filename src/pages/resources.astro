---
import Layout from '../layouts/Layout.astro';

const title = 'Resources — plnt';
const description = 'Three repos, live artifacts, prior art. Where to start reading.';

const source = [
  {
    k: 'plnt (runtime)',
    v: 'The Helm chart, Temporal saga, WorkflowRun CRD, kopf operator, and CLI. The load-bearing infra piece. Apache-2.0.',
    href: 'https://github.com/plnt-work/plnt',
  },
  {
    k: 'microagents (registry)',
    v: 'Pluggable agentic workflow recipes. Each ships as a versioned spec + code, pullable over S3 or OCI. Community-open.',
    href: 'https://github.com/plnt-work/microagents',
  },
  {
    k: 'google-business (product)',
    v: 'AI copilot for Google Business Profile owners. Consumes microagents, deploys via plnt. The end-user proof that the stack works.',
    href: 'https://github.com/plnt-work/google-business',
  },
  {
    k: 'plnt-site (this)',
    v: 'Astro static site + Preact playground. Marketing pages + docs + interactive orchestration demo. Deployed to Vercel.',
    href: 'https://github.com/plnt-work/plnt-site',
  },
];

const artifacts = [
  {
    k: 'Playground',
    v: 'Pick a workflow, watch the orchestration timeline, invoke it. Browser UI backed by the playground API.',
    href: 'https://play.plnt.work',
  },
  {
    k: 'Playground API',
    v: 'HTTP endpoint. <code>/v1/workflows</code>, <code>/v1/workflows/&lt;id&gt;/invoke</code> (SSE), <code>/healthz</code>.',
    href: 'https://playground.plnt.work/v1/workflows',
  },
  {
    k: 'Docker image',
    v: 'Multi-arch python:3.12-slim, ~150 MB, non-root, health-checked. Published to GHCR.',
    href: 'https://github.com/plnt-work/plnt/pkgs/container/plnt-playground-api',
  },
];

const reading = [
  {
    k: 'Temporal patterns',
    v: 'Sagas, compensation, retry policies. The playbook for orchestration workflows that survive process restarts.',
    href: 'https://docs.temporal.io/develop/python/failure-detection',
  },
  {
    k: 'Google SRE — cascading failures',
    v: 'The reason retry budgets sit at the edge (Envoy), not per-hop. Chapter 22 of the SRE book.',
    href: 'https://sre.google/sre-book/addressing-cascading-failures/',
  },
  {
    k: 'KServe',
    v: 'The reference K8s CRD + controller for inference workloads. plnt\'s <code>WorkflowRun</code> borrows heavily from the shape.',
    href: 'https://kserve.github.io/website/',
  },
  {
    k: 'Argo Workflows',
    v: 'DAG-of-steps orchestration on Kubernetes. Inspiration for the workflow spec shape (steps + deps + tool bindings).',
    href: 'https://argoproj.github.io/argo-workflows/',
  },
  {
    k: 'Helm best practices',
    v: 'Chart-per-runner packaging, values.yaml discipline, hooks, tests. The reason plnt does not invent its own package manager.',
    href: 'https://helm.sh/docs/chart_best_practices/',
  },
  {
    k: 'Envoy VirtualService',
    v: 'Traffic weighting for canary → stable transitions. plnt writes VS weights during promote / rollback.',
    href: 'https://www.envoyproxy.io/docs/envoy/latest/api-v3/config/route/v3/route_components.proto#envoy-v3-api-msg-config-route-v3-weightedcluster',
  },
];
---

<Layout title={title} description={description} path="/resources">

  <section class="hero" style="padding-top: clamp(3.5rem, 6vw, 5rem); padding-bottom: clamp(2.5rem, 4vw, 3.5rem);">
    <div class="container">
      <span class="eyebrow">00 / 04 — resources</span>
      <h1 style="max-width: 22ch;">Repos, artifacts, and the reading list behind the design.</h1>
      <p class="lead mt-4" style="max-width: 60ch;">
        Everything is open source. The playground is live. The prior art that shaped
        the design is linked, not assumed.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 04</span> — REPOS</div>
        <div><p class="lead-text">Four repositories, one story.</p></div>
      </div>
      <div class="rows">
        {source.map((d) => (
          <a class="r" href={d.href} target="_blank" rel="noopener">
            <div class="k">{d.k} ↗</div>
            <p class="v" set:html={d.v} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 04</span> — ARTIFACTS</div>
        <div><p class="lead-text">The things you can click, curl, and pull.</p></div>
      </div>
      <div class="rows">
        {artifacts.map((a) => (
          <a class="r" href={a.href} target="_blank" rel="noopener">
            <div class="k">{a.k} ↗</div>
            <p class="v" set:html={a.v} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 04</span> — READING</div>
        <div><p class="lead-text">Prior art the design is built on.</p></div>
      </div>
      <div class="rows">
        {reading.map((r) => (
          <a class="r" href={r.href} target="_blank" rel="noopener">
            <div class="k">{r.k} ↗</div>
            <p class="v" set:html={r.v} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section cream">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 04</span> — QUICK REF</div>
        <div><p class="lead-text">Two minutes on a local kind cluster.</p></div>
      </div>
      <div class="term" style="max-width: 820px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt — kind demo</span>
        </div>
        <div class="body">
          <div><span class="cmt"># create a local cluster</span></div>
          <div><span class="prompt">$</span> kind create cluster --name plnt</div>
          <div style="margin-top: 0.75rem;"><span class="cmt"># install plnt (operator + orchestrator + chart templates)</span></div>
          <div><span class="prompt">$</span> helm install plnt oci://ghcr.io/plnt-work/charts/plnt --version 0.1.0</div>
          <div style="margin-top: 0.75rem;"><span class="cmt"># run a workflow — the operator picks it up and starts the saga</span></div>
          <div><span class="prompt">$</span> kubectl apply -f examples/review-responder.yaml</div>
          <div style="margin-top: 0.75rem;"><span class="cmt"># tail the orchestration log</span></div>
          <div><span class="prompt">$</span> plnt logs review-responder --follow</div>
          <div style="margin-top: 0.75rem;"><span class="cmt"># invoke it</span></div>
          <div><span class="prompt">$</span> curl -s https://review-responder.plnt.svc/invoke \</div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;-H <span class="str">"content-type: application/json"</span> \</div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;-d <span class="str">{`'{"review":{"rating":2,"text":"..."}}'`}</span></div>
        </div>
      </div>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="https://play.plnt.work" target="_blank" rel="noopener">Open playground <span class="arrow">→</span></a>
        <a class="btn" href="/architecture">Architecture</a>
        <a class="btn" href="/roadmap">Roadmap</a>
      </div>
    </div>
  </section>

</Layout>

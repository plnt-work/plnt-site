---
import Layout from '../layouts/Layout.astro';

const title = 'Resources — plnt';
const description = 'Documentation, source code, reading list, and a quick CLI / HTTP reference.';

const docs = [
  { k: 'README', v: 'What plnt is and the one-paragraph pitch.', href: 'https://github.com/devdattatalele/plnt/blob/main/README.md' },
  { k: 'ARCHITECTURE.md', v: 'File-by-file mapping of the four planes.', href: 'https://github.com/devdattatalele/plnt/blob/main/ARCHITECTURE.md' },
  { k: 'SETUP.md', v: 'Cross-platform install guide. macOS + Linux. Ollama + cloud backends.', href: 'https://github.com/devdattatalele/plnt/blob/main/SETUP.md' },
  { k: 'IMPROVEMENTS.md', v: 'v0 → v0.1 punch list. Resident planner, streaming ACC, episodic memory, mTLS.', href: 'https://github.com/devdattatalele/plnt/blob/main/IMPROVEMENTS.md' },
];

const source = [
  { k: 'GitHub', v: '~4,800 LOC Python runtime + Go Bubble Tea TUI.', href: 'https://github.com/devdattatalele/plnt' },
  { k: 'LICENSE', v: 'Apache 2.0. Permissive. Use commercially, fork, modify.', href: 'https://github.com/devdattatalele/plnt/blob/main/LICENSE' },
  { k: 'Issues', v: 'Bugs, feature requests, design discussion. Pre-alpha — everything is fair game.', href: 'https://github.com/devdattatalele/plnt/issues' },
];

const reading = [
  { k: 'Beyond Scaling', v: 'arXiv:2605.18535 — the thesis behind running agent runtimes on your own hardware.', href: 'https://arxiv.org/abs/2605.18535' },
  { k: 'HearthNet', v: 'arXiv:2604.09618 — inspiration for the file-backed, audit-first memory model.', href: 'https://arxiv.org/abs/2604.09618' },
  { k: 'exo', v: 'Federated local inference. plnt routes to exo by pointing PLNT_DEEP_URL at a cluster.', href: 'https://github.com/exo-explore/exo' },
  { k: 'Firecracker / gVisor', v: 'The microVM and user-space-kernel sandboxes that future plnt rungs target.', href: 'https://firecracker-microvm.github.io/' },
];
---

<Layout title={title} description={description} path="/resources">

  <section class="section" style="padding-top: clamp(5rem, 9vw, 7rem); padding-bottom: clamp(4rem, 6vw, 5rem);">
    <div class="container">
      <span class="eyebrow">00 / 04 — resources</span>
      <h1 style="max-width: 22ch;">Read, install, hack.</h1>
      <p class="lead mt-4" style="max-width: 56ch;">
        The repository is the source of truth. This page is a map of where to start
        and what to read.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 04</span> — DOCS</div>
        <p class="lead-text">Project documentation lives in the repo.</p>
      </div>
      <div class="rows">
        {docs.map((d) => (
          <a class="r r-link" href={d.href} target="_blank" rel="noopener">
            <div class="k">{d.k} ↗</div>
            <p class="v">{d.v}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 04</span> — SOURCE</div>
        <p class="lead-text">Code, license, issue tracker.</p>
      </div>
      <div class="rows">
        {source.map((d) => (
          <a class="r r-link" href={d.href} target="_blank" rel="noopener">
            <div class="k">{d.k} ↗</div>
            <p class="v">{d.v}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 04</span> — READING</div>
        <p class="lead-text">Papers and projects that shape plnt.</p>
      </div>
      <div class="rows">
        {reading.map((d) => (
          <a class="r r-link" href={d.href} target="_blank" rel="noopener">
            <div class="k">{d.k} ↗</div>
            <p class="v">{d.v}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 04</span> — QUICK REF</div>
        <p class="lead-text">Two minutes, end to end.</p>
      </div>
      <div class="term" style="max-width: 760px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt — bash</span>
        </div>
        <div class="body">
          <div><span class="cmt"># install</span></div>
          <div><span class="prompt">$</span> git clone https://github.com/devdattatalele/plnt</div>
          <div><span class="prompt">$</span> cd plnt && pip install -e <span class="str">"."</span></div>
          <div style="margin-top: 0.85rem;"><span class="cmt"># CLI</span></div>
          <div><span class="prompt">$</span> plnt submit <span class="str">"find anything on agent memory in my Documents"</span></div>
          <div><span class="prompt">$</span> plnt up &</div>
          <div><span class="prompt">$</span> plnt runs</div>
          <div><span class="prompt">$</span> plnt tail r-XXXXXXXX --follow</div>
          <div><span class="prompt">$</span> plnt skills list</div>
          <div style="margin-top: 0.85rem;"><span class="cmt"># HTTP / SSE</span></div>
          <div><span class="kw">POST</span> /v1/intents</div>
          <div><span class="kw">GET</span>  /v1/runs</div>
          <div><span class="kw">GET</span>  /v1/runs/&#123;id&#125;/stream</div>
          <div><span class="kw">GET</span>  /v1/skills</div>
          <div><span class="kw">GET</span>  /v1/health</div>
        </div>
      </div>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="/docs/">Open the docs portal <span class="arrow">→</span></a>
        <a class="btn" href="/architecture">Architecture</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .r-link { text-decoration: none; transition: background 0.12s ease; display: grid; }
  .r-link .v { color: var(--ink-3); }
  .r-link:hover .k { color: var(--acc); }
  .r-link:hover .v { color: var(--ink-2); }
</style>

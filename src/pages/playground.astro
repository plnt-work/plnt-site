---
import Layout from '../layouts/Layout.astro';
import Playground from '../islands/playground/Playground';
import '../styles/playground.css';

const title = 'plnt — playground';
const description = 'Pick a micro-agent workflow, pick a GPU backend, watch plnt orchestrate the run. Every workflow is a Temporal saga on a Helm-deployed runner pod.';
---

<Layout title={title} description={description} path="/playground">
  <Playground client:load />
</Layout>

<style is:global>
  main { padding: 0; }
</style>

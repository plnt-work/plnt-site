---
import Layout from '../layouts/Layout.astro';
import ArchDiagram from '../components/ArchDiagram.astro';
import SpawnGraph from '../components/SpawnGraph.astro';
import LogStream from '../components/LogStream.astro';
import { Code } from 'astro:components';

const title = 'Architecture — plnt';
const description = 'Four planes. AgentSpec as the only contract. Blackboard as the audit story. Two tools only. The sandbox is a ladder.';

const agentSpecCode = `class AgentSpec(BaseModel):
    # Identity
    id: str = Field(default_factory=lambda: f"a-{uuid.uuid4().hex[:10]}")
    role: str                                      # → skills/<role>.md
    run_id: str
    parent_id: str | None = None
    depth: int = Field(default=0, ge=0, le=HARD_MAX_DEPTH)

    # Capability
    lifetime: Literal["ephemeral", "resident"] = "ephemeral"
    isolation: Literal["process", "docker", "gvisor", "microvm", "wasm"] = "process"
    tools: list[str] = Field(default_factory=lambda: ["search", "execute"])

    # I/O
    inputs: dict[str, Any] = Field(default_factory=dict)
    output_schema: dict[str, Any] | None = None
    blackboard_scope: str | None = None

    # Compute hints — the router decides; the planner only hints.
    model_hint: Literal["small", "deep", "auto"] = "auto"

    # Budget
    budget: Budget = Field(default_factory=Budget)


class Budget(BaseModel):
    tokens: int = 20_000
    wall_seconds: int = 300
    joules: int = 0`;

const eventKindCode = `EventKind = Literal[
    "intent", "spawn", "started", "tool_call", "tool_result",
    "log", "model_call", "model_result", "budget_tick",
    "result", "error", "killed", "finished",
]
# Orchestration also emits:
#   "triage_start", "triage", "plan", "fs_change"`;

const toolsCode = `def search(pattern, root, *, allowed_roots, max_hits=200,
           case_sensitive=False, file_glob=None) -> list[SearchHit]:
    """Regex match under 'root'. Any path outside allowed_roots
    raises SearchError. Ripgrep when available."""

def execute(argv, *, workdir, allowed_roots, timeout_seconds=30,
            max_output_bytes=256*1024, env=None) -> ExecuteResult:
    """Bounded child process. argv list — no shell interpolation.
    Blocks sudo / su / doas. Stdout capped at 256 KB."""`;

const skillPromptMd = `You are literature-scout — an ephemeral micro-agent the
research-librarian spawns to locate candidate sources.

Given inputs.library_root and inputs.query, return a JSON
array of {path, why} entries — the paths that look relevant
and a one-line reason for each. Use search() first; only
execute() for listings.

Do not summarise the papers — that is paper-reader's job.
Stop as soon as you have a candidate list.`;

const realLog = [
  { ts: '04:17:33', kind: 'intent', payload: '<span class="v">"find anything on agent memory in my Documents"</span>' },
  { ts: '04:17:33', kind: 'triage', payload: 'simple_task · general-helper' },
  { ts: '04:17:33', kind: 'plan', payload: 'agent_count=1 · a-6e038660' },
  { ts: '04:17:33', kind: 'spawn', payload: 'a-6e038660 · isolation=process · model_hint=small' },
  { ts: '04:17:33', kind: 'model_call', payload: 'step=1' },
  { ts: '04:17:33', kind: 'tool_call', payload: 'search(".", "~/Documents/plnt")' },
  { ts: '04:17:34', kind: 'tool_result', payload: 'ok' },
  { ts: '04:17:34', kind: 'finished', payload: 'exit=ok · wall=0.9s · tokens=412' },
];

const rungs = [
  { k: 'Rung 0 · process', v: '<strong>Shipping.</strong> Subprocess + rlimits + watchdog. The default. ~273 LOC at <code>sandbox/process.py</code>.' },
  { k: 'Rung 1 · docker', v: '<strong>Shipping.</strong> CPU and memory caps, parallel-safe via labelled containers. ~290 LOC.' },
  { k: 'Rung 2 · gVisor', v: '<strong>Future.</strong> User-space kernel isolation without the VM cost. Registered stub.' },
  { k: 'Rung 3 · Firecracker µVM', v: '<strong>Future.</strong> Hard tenancy. Reserved for LLM-emitted code that touches the network.' },
];

const router = [
  { k: '01 · local', v: 'If <code>PLNT_REQUIRED_PATH</code> is mounted (or unset) <strong>and</strong> <code>PLNT_LOCAL_URL</code> (default <code>http://127.0.0.1:11434</code>) is reachable.' },
  { k: '02 · cloud', v: 'If <code>PLNT_CLOUD_URL</code> + <code>PLNT_CLOUD_API_KEY</code> are configured and reachable.' },
  { k: '03 · offline echo', v: 'Otherwise. Deterministic. The test suite runs against this path — no LLM required.' },
];
---

<Layout title={title} description={description} path="/architecture">

  <section class="section" style="padding-top: clamp(5rem, 9vw, 7rem); padding-bottom: clamp(4rem, 7vw, 5rem);">
    <div class="container">
      <span class="eyebrow">00 / 09 — architecture</span>
      <h1 style="max-width: 24ch;">Four planes. One hard contract.</h1>
      <p class="lead mt-4" style="max-width: 60ch;">
        Surface, Control, Execution, Compute — each owns one responsibility.
        The only object that crosses Control → Execution is the <code>AgentSpec</code>.
        Everything you want to enforce on a spawn lives on it.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 09</span> — PLANES</div>
        <p class="lead-text">The four planes, with their modules.</p>
      </div>
      <ArchDiagram />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 09</span> — RULES</div>
        <p class="lead-text">Four rules the codebase enforces.</p>
      </div>
      <div class="rows">
        <div class="r">
          <div class="k">Rule 01</div>
          <p class="v"><strong>AgentSpec is the only Control → Execution object.</strong> Role, search roots, token + wall-second budget, isolation rung, tools — everything Control wants to enforce on a spawn is on the spec.</p>
        </div>
        <div class="r">
          <div class="k">Rule 02</div>
          <p class="v"><strong>Two tools, ever: <code>search</code> and <code>execute</code>.</strong> The RLM pattern. Context lives in the filesystem; anything else is reachable through these. There will not be a third.</p>
        </div>
        <div class="r">
          <div class="k">Rule 03</div>
          <p class="v"><strong>Blackboard is the audit story.</strong> Every observable event is one JSONL line: <code>intent → spawn → started → model_call → tool_call → tool_result → result → finished</code>. SIGTERM kills still emit a transcript summary.</p>
        </div>
        <div class="r">
          <div class="k">Rule 04</div>
          <p class="v"><strong>Framework owns memory, skills, and the sandbox.</strong> The model is a swappable backend. Skills are markdown the framework reads on file change. No MCP. No vendor SDK in the middle.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 09</span> — SPEC</div>
        <p class="lead-text">
          From <code>plnt/execution/spec.py</code>. Pydantic <code>BaseModel</code>.
          Every spawn boundary in the system is one of these.
        </p>
      </div>
      <div class="term" style="max-width: 880px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/execution/spec.py</span>
        </div>
        <div class="body">
          <Code code={agentSpecCode} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 09</span> — EVENTS</div>
        <p class="lead-text">
          Every observable change of state in the system is one of these.
          If <code>cat</code> can't see it, it doesn't exist as state.
        </p>
      </div>
      <div class="term" style="max-width: 720px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/execution/blackboard.py</span>
        </div>
        <div class="body">
          <Code code={eventKindCode} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">05 <span class="of">/ 09</span> — FLOW</div>
        <p class="lead-text">
          A single intent traverses the system. ACC and budget governor watch the streams in real time.
        </p>
      </div>
      <SpawnGraph />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">06 <span class="of">/ 09</span> — LIVE LOG</div>
        <p class="lead-text">
          Captured from a real run. <code>~/.plnt/runs/r-2a5c42e150/events.jsonl</code>.
        </p>
      </div>
      <div class="term" style="max-width: 880px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>events.jsonl · r-2a5c42e150</span>
        </div>
        <div class="body">
          <LogStream events={realLog} />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">07 <span class="of">/ 09</span> — TOOLS</div>
        <p class="lead-text">
          Every agent gets exactly these — <code>search</code> and <code>execute</code>.
          Both enforce <code>allowed_roots</code> as a hard security boundary.
        </p>
      </div>
      <div class="term" style="max-width: 880px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/execution/tools/</span>
        </div>
        <div class="body">
          <Code code={toolsCode} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">08 <span class="of">/ 09</span> — SANDBOX</div>
        <p class="lead-text">
          The sandbox is a ladder. Two rungs ship today; two are registered as stubs.
        </p>
      </div>
      <div class="rows">
        {rungs.map((r) => (
          <div class="r">
            <div class="k">{r.k}</div>
            <p class="v" set:html={r.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">09 <span class="of">/ 09</span> — COMPUTE</div>
        <p class="lead-text">
          One router, three backends. Every decision lands in <code>events.jsonl</code> so
          <code>grep -F '"backend":"cloud"'</code> is a real audit query.
        </p>
      </div>
      <div class="rows">
        {router.map((r) => (
          <div class="r">
            <div class="k">{r.k}</div>
            <p class="v" set:html={r.v} />
          </div>
        ))}
      </div>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="/docs/concepts/four-planes/">Read the docs <span class="arrow">→</span></a>
        <a class="btn" href="/roadmap">Roadmap</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">10 <span class="of">/ 09</span> — SKILLS</div>
        <p class="lead-text">
          A skill is one markdown file plus a TOML manifest. Hot-reloaded on file change.
          Below: <code>literature-scout/prompt.md</code>.
        </p>
      </div>
      <div class="term" style="max-width: 720px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>skills/literature-scout/prompt.md</span>
        </div>
        <div class="body">
          <Code code={skillPromptMd} lang="markdown" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

</Layout>

---
import Layout from '../layouts/Layout.astro';
import LogStream from '../components/LogStream.astro';
import { Code } from 'astro:components';

const title = 'Architecture — plnt';
const description = 'Helm chart per runtime · Temporal deploy saga · InferenceModel CRD · Python operator · RuntimeAdapter · canary via Envoy · benchmarking · plnt-cloud as consumer.';

const crdSpec = `apiVersion: plnt.work/v1
kind: InferenceModel
metadata:
  name: llama-3.1-70b-instruct
spec:
  runtime: vllm                     # vllm | tgi | trt-llm | sglang
  model:
    name: meta-llama/Llama-3.1-70B-Instruct
    storageUri: s3://plnt-models/llama-3.1-70b/fp16
    quantization: fp16              # fp16 | fp8 | awq-4bit | gptq-4bit
  resources:
    gpu: 2
    gpuClass: nvidia.com/h100
    memoryGiB: 160
  replicas:
    min: 1
    max: 4
  autoscaling:
    targetTokensPerSecond: 1500
  canary:
    trafficPercent: 5
    smokeTest:
      prompts: 10
      ttftBudgetMs: 250
      tpotBudgetMs: 40`;

const operatorCode = `# plnt/operators/inferencemodel_controller.py
import kopf
from temporalio.client import Client
from plnt.workflows.deploy_model import DeployModelWorkflow

@kopf.on.create('plnt.work', 'v1', 'inferencemodels')
async def on_create(spec, name, namespace, **_):
    client = await Client.connect(TEMPORAL_ADDR)
    await client.start_workflow(
        DeployModelWorkflow.run,
        args=[spec],
        id=f'deploy-{namespace}-{name}',
        task_queue='plnt-deploys',
    )

@kopf.on.update('plnt.work', 'v1', 'inferencemodels')
async def on_update(spec, name, namespace, **_):
    # Any update to the manifest triggers a fresh canary.
    ...

@kopf.on.delete('plnt.work', 'v1', 'inferencemodels')
async def on_delete(name, namespace, **_):
    # helm uninstall the release; cancel any in-flight workflow.
    ...`;

const sagaCode = `# plnt/workflows/deploy_model.py
from datetime import timedelta
from temporalio import workflow
from temporalio.common import RetryPolicy

@workflow.defn
class DeployModelWorkflow:
    @workflow.run
    async def run(self, spec: dict) -> dict:
        retry = RetryPolicy(
            initial_interval=timedelta(seconds=2),
            maximum_attempts=3,
            backoff_coefficient=2.0,
            non_retryable_error_types=['ManifestInvalid', 'ImageUnpullable'],
        )
        try:
            await workflow.execute_activity(
                validate_manifest, spec, start_to_close_timeout=timedelta(seconds=30), retry_policy=retry)
            await workflow.execute_activity(
                pull_and_verify_weights, spec, start_to_close_timeout=timedelta(minutes=30), retry_policy=retry)
            release = await workflow.execute_activity(
                helm_install_canary, spec, start_to_close_timeout=timedelta(minutes=10), retry_policy=retry)
            smoke = await workflow.execute_activity(
                run_smoke_test, release, start_to_close_timeout=timedelta(minutes=5), retry_policy=retry)
            if not smoke['passed']:
                await workflow.execute_activity(helm_rollback, release)
                return {'status': 'rolled_back', 'reason': smoke['reason']}
            await workflow.execute_activity(
                promote_to_stable, release, start_to_close_timeout=timedelta(minutes=5))
            return {'status': 'ready', 'endpoint': release['endpoint']}
        except Exception as e:
            await workflow.execute_activity(helm_rollback, spec)  # compensation
            raise`;

const runtimeAdapter = `# plnt/runtime/base.py
from typing import Protocol, AsyncIterator
from plnt.playground.schemas import ChatCompletionRequest, ChatCompletionResponse

class RuntimeAdapter(Protocol):
    """One interface, four backends: vLLM, TGI, TRT-LLM, SGLang."""
    model_id: str
    runtime: str

    async def complete(
        self, req: ChatCompletionRequest,
    ) -> ChatCompletionResponse: ...

    def stream(
        self, req: ChatCompletionRequest,
    ) -> AsyncIterator: ...

    async def readyz(self) -> bool: ...
    async def metrics(self) -> dict: ...  # TTFT / TPOT / tokens-per-s / KV-cache-util`;

const deployLog = [
  { ts: '04:17:33', kind: 'watch',       payload: 'InferenceModel/<span class="v">llama-3.1-70b-instruct</span> event=<span class="v">create</span>' },
  { ts: '04:17:33', kind: 'workflow',    payload: 'start · <span class="v">deploy-default-llama-3.1-70b-instruct</span>' },
  { ts: '04:17:34', kind: 'validate',    payload: 'schema ok · storage_uri reachable · image pullable · gpu class available' },
  { ts: '04:17:36', kind: 'pull',        payload: 'safetensors · 141 GiB · sha256 verified · CAS hit=<span class="v">partial</span>' },
  { ts: '04:18:02', kind: 'helm',        payload: 'install release=<span class="v">llama-70b-canary</span> · replicas=1 · vs.weight=5%' },
  { ts: '04:19:41', kind: 'smoke',       payload: 'n=10 · TTFT p50=<span class="v">182ms</span> p95=241ms · TPOT p50=<span class="v">28ms</span> · pass' },
  { ts: '04:19:42', kind: 'promote',     payload: 'canary → stable · vs.weight=100% · replicas=1→3' },
  { ts: '04:19:42', kind: 'ready',       payload: 'endpoint=<span class="v">llama-3.1-70b-instruct.plnt.svc/v1/chat/completions</span>' },
];

const runtimes = [
  { k: 'vLLM', v: '<strong>Chart <code>vllm-runtime</code>.</strong> Paged attention, continuous batching, prefix cache. FP16 / FP8 / AWQ / GPTQ. Default runtime for dense LLM serving.' },
  { k: 'TGI', v: '<strong>Chart <code>tgi-runtime</code>.</strong> Hugging Face Text Generation Inference. Flash-attention 2, tensor parallel via <code>num_shard</code>, GPTQ / AWQ / FP8.' },
  { k: 'TRT-LLM', v: '<strong>Chart <code>trt-llm-runtime</code>.</strong> Precompiled TensorRT engines on Triton Inference Server. Engine build runs as a workflow step; cold start ~7 min, warm ~40 s.' },
  { k: 'SGLang', v: '<strong>Chart <code>sglang-runtime</code>.</strong> RadixAttention prefix caching. Structured generation via SGL DSL. Best-in-class for reasoning models with long CoT traces.' },
];

const gaps = [
  { k: 'GPU access', v: '<strong>No real GPU hardware yet.</strong> The demo playground proxies to NVIDIA NIM hosted APIs. The Helm charts are shaped for real GPU nodes; hardening on H100/A100 spot instances is the next quarter of work.' },
  { k: 'BuildKit / CUDA images', v: '<strong>Multi-arch CUDA base images are new territory.</strong> One working <code>runtime.Dockerfile</code> ships; industrialising the build pipeline (NVIDIA container toolkit, multi-stage CUDA, image signing) is stated future work.' },
  { k: 'Multi-cluster', v: '<strong>Single-cluster demo.</strong> Multi-cluster deploy sagas are a design I understand (fan-out activities keyed by cluster context, per-cluster canary), not code I\'ve run at scale.' },
  { k: 'Benchmarking loop', v: '<strong>Metrics scaffold exists; the p99-alert automation does not.</strong> TTFT / TPOT / tokens-per-s / KV-cache-util are captured; wiring them to Grafana + PagerDuty for regression alerts is Phase 6.' },
];
---

<Layout title={title} description={description} path="/architecture">

  <section class="section" style="padding-top: clamp(5rem, 9vw, 7rem); padding-bottom: clamp(4rem, 7vw, 5rem);">
    <div class="container">
      <span class="eyebrow">00 / 09 — architecture</span>
      <h1 style="max-width: 24ch;">The CRD is the deploy contract. The saga is the deploy engine.</h1>
      <p class="lead mt-4" style="max-width: 62ch;">
        plnt is nine pieces: a CRD, an operator, a Temporal workflow, four runtime Helm charts,
        an Envoy router, and a benchmarking harness. Each piece is small enough to explain
        on one screen.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">01 <span class="of">/ 09</span> — DIAGRAM</div>
        <p class="lead-text">
          One K8s cluster. One operator. One workflow engine. N runtimes.
        </p>
      </div>
      <div class="term" style="max-width: 920px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt · single-cluster topology</span>
        </div>
        <div class="body">
<pre style="font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.6; color: var(--ink-2); margin: 0;">     plnt CLI                    kubectl                    plnt-cloud
        │                          │                            │
        └──────────────┬───────────┘                            │
                       ▼                                        │
        ┌─────────────────────────────┐                         │
        │  InferenceModel  (K8s CRD)  │                         │
        └──────────────┬──────────────┘                         │
                       │  watch                                 │
                       ▼                                        │
        ┌─────────────────────────────┐                         │
        │  plnt operator  (kopf)      │                         │
        └──────────────┬──────────────┘                         │
                       │  start_workflow(spec)                  │
                       ▼                                        │
     ┌───────────────────────────────────────────┐              │
     │  Temporal · DeployModelWorkflow           │              │
     │  validate → pull → helm → smoke → promote │              │
     │       └────────────┴──────────┴──▶ rollback              │
     └───────────────────────────────────────────┘              │
                       │  helm install                          │
                       ▼                                        │
     ┌──────────┬──────────┬──────────┬──────────┐              │
     │  vllm-   │  tgi-    │ trt-llm- │ sglang-  │              │
     │  runtime │  runtime │  runtime │  runtime │              │
     └──────────┴──────────┴──────────┴──────────┘              │
                       │                                        │
                       ▼                                        │
                ┌──────────────┐                                │
                │ envoy router │  (VirtualService weights)      │
                └──────┬───────┘                                │
                       │                                        │
                       ▼                                        │
               /v1/chat/completions  ◀────────────────────── consume
</pre>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">02 <span class="of">/ 09</span> — CRD</div>
        <p class="lead-text">
          The <code>InferenceModel</code> resource is the entire deploy contract.
          Everything the operator, the workflow, and the Helm chart need is on the spec.
        </p>
      </div>
      <div class="term" style="max-width: 900px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>examples/llama-3.1-70b-instruct.yaml</span>
        </div>
        <div class="body">
          <Code code={crdSpec} lang="yaml" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">03 <span class="of">/ 09</span> — OPERATOR</div>
        <p class="lead-text">
          A Python <code>kopf</code> controller watches the CRD.
          Create / update / delete map directly to Temporal workflow starts, updates, and cancellations.
        </p>
      </div>
      <div class="term" style="max-width: 900px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/operators/inferencemodel_controller.py</span>
        </div>
        <div class="body">
          <Code code={operatorCode} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">04 <span class="of">/ 09</span> — SAGA</div>
        <p class="lead-text">
          The deploy saga is a Temporal workflow. Compensation on failure via <code>helm rollback</code>.
          Retries per activity with budgets. Non-retryable error types short-circuit obvious dead-ends.
        </p>
      </div>
      <div class="term" style="max-width: 900px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/workflows/deploy_model.py</span>
        </div>
        <div class="body">
          <Code code={sagaCode} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">05 <span class="of">/ 09</span> — LIVE LOG</div>
        <p class="lead-text">
          One deploy run. Captured from the Temporal event history for
          <code>deploy-default-llama-3.1-70b-instruct</code>.
        </p>
      </div>
      <div class="term" style="max-width: 900px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>temporal · workflow history · r-9c4f218e0a</span>
        </div>
        <div class="body">
          <LogStream events={deployLog} />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">06 <span class="of">/ 09</span> — RUNTIMES</div>
        <p class="lead-text">
          Four charts, one control API. Each speaks OpenAI wire format at the pod boundary.
        </p>
      </div>
      <div class="rows">
        {runtimes.map((r) => (
          <div class="r">
            <div class="k">{r.k}</div>
            <p class="v" set:html={r.v} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">07 <span class="of">/ 09</span> — ADAPTER</div>
        <p class="lead-text">
          The chart per runtime is the deployment shape. The <code>RuntimeAdapter</code> Protocol
          is the code shape. Adding a fifth backend is one class, not a fork.
        </p>
      </div>
      <div class="term" style="max-width: 900px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt/runtime/base.py</span>
        </div>
        <div class="body">
          <Code code={runtimeAdapter} lang="python" theme="github-dark-default" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">08 <span class="of">/ 09</span> — BENCH</div>
        <p class="lead-text">
          The metrics that prove the platform works: <code>TTFT</code> (time-to-first-token),
          <code>TPOT</code> (time-per-output-token), tokens/sec/GPU, KV-cache utilization.
          Scraped from each runtime's <code>/metrics</code> endpoint into Prometheus.
        </p>
      </div>
      <div class="term" style="max-width: 780px;">
        <div class="chrome">
          <span class="dots"><span></span><span></span><span></span></span>
          <span>plnt bench --model llama-3.1-70b-instruct --qps 10 --duration 60s</span>
        </div>
        <div class="body">
<pre style="margin: 0; font-family: var(--font-mono); font-size: 0.78rem; line-height: 1.7; color: var(--ink-2);">TTFT      p50 =   182 ms   p95 =   241 ms   p99 =   289 ms
TPOT      p50 =    28 ms   p95 =    34 ms   p99 =    41 ms
tokens/s/GPU               =   87.3
KV cache util             =   72 %
prefix cache hit rate     =   41 %
</pre>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sechead">
        <div class="count">09 <span class="of">/ 09</span> — GAPS</div>
        <p class="lead-text">
          Where the current build is honest about what it isn't. Named upfront, not hidden.
        </p>
      </div>
      <div class="rows">
        {gaps.map((g) => (
          <div class="r">
            <div class="k">{g.k}</div>
            <p class="v" set:html={g.v} />
          </div>
        ))}
      </div>
      <div class="flex gap wrap mt-5">
        <a class="btn primary" href="https://play.plnt.work" target="_blank" rel="noopener">Open playground <span class="arrow">→</span></a>
        <a class="btn" href="/roadmap">Roadmap</a>
        <a class="btn" href="https://github.com/devdattatalele/plnt" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

</Layout>

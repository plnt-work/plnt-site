---
import Layout from '../layouts/Layout.astro';
import ArchDiagram from '../components/ArchDiagram.astro';
import SpawnGraph from '../components/SpawnGraph.astro';
import TerminalWindow from '../components/TerminalWindow.astro';
import LogStream from '../components/LogStream.astro';
import { Code } from 'astro:components';

const title = 'Architecture — plnt';
const description = 'Four planes. AgentSpec as the only contract. Blackboard as the audit story. Two tools only. The sandbox is a ladder.';

const agentSpecCode = `class AgentSpec(BaseModel):
    # Identity
    id: str = Field(default_factory=lambda: f"a-{uuid.uuid4().hex[:10]}")
    role: str                                      # → skills/<role>.md
    run_id: str
    parent_id: str | None = None
    depth: int = Field(default=0, ge=0, le=HARD_MAX_DEPTH)

    # Capability
    lifetime: Literal["ephemeral", "resident"] = "ephemeral"
    isolation: Literal["process", "docker", "gvisor", "microvm", "wasm"] = "process"
    tools: list[str] = Field(default_factory=lambda: ["search", "execute"])

    # I/O
    inputs: dict[str, Any] = Field(default_factory=dict)
    output_schema: dict[str, Any] | None = None
    blackboard_scope: str | None = None

    # Compute hints — the router decides; the planner only hints.
    model_hint: Literal["small", "deep", "auto"] = "auto"

    # Budget
    budget: Budget = Field(default_factory=Budget)


class Budget(BaseModel):
    tokens: int = 20_000
    wall_seconds: int = 300
    joules: int = 0`;

const eventKindCode = `EventKind = Literal[
    "intent", "spawn", "started", "tool_call", "tool_result",
    "log", "model_call", "model_result", "budget_tick",
    "result", "error", "killed", "finished",
]
# Orchestration also emits:
#   "triage_start", "triage", "plan", "fs_change"`;

const toolsCode = `def search(
    pattern: str,
    root: str | Path,
    *,
    allowed_roots: list[Path],
    max_hits: int = 200,
    case_sensitive: bool = False,
    file_glob: str | None = None,
) -> list[SearchHit]:
    """Search 'pattern' (regex) under 'root'. Any path outside
    allowed_roots raises SearchError."""

def execute(
    argv: list[str],
    *,
    workdir: Path,
    allowed_roots: list[Path],
    timeout_seconds: int = 30,
    max_output_bytes: int = 256 * 1024,
    env: dict[str, str] | None = None,
) -> ExecuteResult:
    """Bounded child process. argv list — no shell interpolation.
    Blocks sudo / su / doas. workdir ⊆ allowed_roots."""`;

const skillPromptMd = `You are literature-scout — an ephemeral micro-agent the
research-librarian spawns to locate candidate sources.

Given inputs.library_root and inputs.query, return a JSON
array of {path, why} entries — the paths that look relevant
and a one-line reason for each. Use search() first; only
execute() for listings (e.g. arXiv lookups via the user's
bibliography scripts).

Do not summarise the papers — that is paper-reader's job.
Stop as soon as you have a candidate list.`;

const skillToml = `[meta]
name = "literature-scout"
version = "0.2"
description = "Surface candidate papers for the librarian"

[runtime]
model_hint = "small"
tools = ["search", "execute"]
default_isolation = "process"

[budget]
tokens = 8_000
wall_seconds = 120

[output]
schema = "object"
required = ["candidates"]`;

const realLog = [
  { ts: '04:17:33', kind: 'intent', payload: '<span class="v">"find anything on agent memory in my Documents"</span>' },
  { ts: '04:17:33', kind: 'plan', payload: 'agent_count=1 · general-helper' },
  { ts: '04:17:33', kind: 'spawn', payload: 'a-6e038660 · role=general-helper · isolation=process' },
  { ts: '04:17:33', kind: 'model_call', payload: 'step=1 · model_hint=small' },
  { ts: '04:17:33', kind: 'tool_call', payload: 'search("agent memory", "~/Documents")' },
  { ts: '04:17:34', kind: 'tool_result', payload: 'ok · 17 hits' },
  { ts: '04:17:34', kind: 'result', payload: '<span class="v">~/Desktop/plnt-r-2a5c42e150.md</span>' },
  { ts: '04:17:34', kind: 'finished', payload: 'exit=ok · wall_seconds=0.9 · tokens=412' },
];
---

<Layout title={title} description={description} path="/architecture">

  <section class="section" style="padding-top: clamp(3.5rem, 6vw, 5rem); padding-bottom: clamp(2.5rem, 5vw, 3.5rem);">
    <div class="container narrow center">
      <span class="eyebrow">architecture</span>
      <h1>Four planes. One hard contract.</h1>
      <p class="lead dim" style="margin: 1.25rem auto 0; max-width: 60ch;">
        Surface, Control, Execution, Compute — each owns one responsibility.
        The only object that crosses Control → Execution is the <code>AgentSpec</code>.
        Everything you want to enforce on a spawn lives on it.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <ArchDiagram />
    </div>
  </section>

  <section class="section tinted">
    <div class="container">
      <span class="eyebrow">hard rules</span>
      <h2>Four rules the codebase enforces.</h2>
      <div class="grid-2 mt-4">
        <div class="card">
          <span class="tag">rule 01</span>
          <h3>AgentSpec is the only contract</h3>
          <p>Role, search roots, token + wall-second budget, isolation rung, tools — everything Control wants to enforce on a spawn is on the spec. Nothing else crosses the boundary.</p>
        </div>
        <div class="card">
          <span class="tag">rule 02</span>
          <h3>Two tools, ever</h3>
          <p><code>search</code> and <code>execute</code>. The Restricted Language Model pattern. Context lives in the filesystem; anything else is reachable through these. There will not be a third.</p>
        </div>
        <div class="card">
          <span class="tag">rule 03</span>
          <h3>Blackboard is the audit story</h3>
          <p>Every observable event is one JSONL line: <code>intent → spawn → started → model_call → tool_call → tool_result → result → finished</code>. SIGTERM kills still emit a <code>transcript-summary</code>.</p>
        </div>
        <div class="card">
          <span class="tag">rule 04</span>
          <h3>Framework owns memory + skills + sandbox</h3>
          <p>The model is a swappable backend. Skills are markdown files the framework reads on file change. No MCP. No vendor-controlled SDK in the middle.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">execution · spec.py</span>
          <h2>AgentSpec</h2>
          <p class="lead dim">
            From <code>plnt/execution/spec.py</code>. Every spawn boundary in the system is
            one of these — a Pydantic <code>BaseModel</code> with budget, isolation, and tool fields.
          </p>
          <ul class="bullet-list">
            <li><strong>Identity.</strong> auto-generated <code>id</code>, parent_id, depth (hard-capped).</li>
            <li><strong>Capability.</strong> isolation rung, two-tool default, lifetime.</li>
            <li><strong>I/O.</strong> inputs, output schema, blackboard scope glob.</li>
            <li><strong>Budget.</strong> tokens, wall-seconds, joules — enforced by the governor.</li>
          </ul>
        </div>
        <div>
          <TerminalWindow title="plnt/execution/spec.py">
            <Code code={agentSpecCode} lang="python" theme="github-dark-default" />
          </TerminalWindow>
        </div>
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container">
      <div class="split">
        <div>
          <TerminalWindow title="plnt/execution/blackboard.py">
            <Code code={eventKindCode} lang="python" theme="github-dark-default" />
          </TerminalWindow>
        </div>
        <div>
          <span class="eyebrow">execution · blackboard.py</span>
          <h2>Blackboard event types</h2>
          <p class="lead dim">
            Every observable change of state is one JSONL line. If <code>cat</code> can't see it,
            it doesn't exist as state.
          </p>
          <p>
            The same file is the source of truth for the TUI, future dashboards, replays,
            and your audit queries. No database. No second source of truth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center">
        <span class="eyebrow">one intent, end to end</span>
        <h2>From "papers by 7am" to a markdown file on your Desktop.</h2>
        <p class="lead dim center" style="margin: 1rem auto 0; max-width: 56ch;">
          A single intent traverses the system. ACC and the budget governor watch the streams in real time.
        </p>
      </div>
      <div class="mt-5">
        <SpawnGraph />
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">real run · r-2a5c42e150</span>
          <h2>A live audit log.</h2>
          <p class="lead dim">
            Captured from a real run. The lifecycle is intent → triage → plan → spawn → model_call →
            tool_call → tool_result → result → finished.
          </p>
          <p>
            Every line is grep-able. Every backend decision lands here too —
            <code>grep -F '"backend":"cloud"'</code> is a real audit query.
          </p>
        </div>
        <div>
          <TerminalWindow title="~/.plnt/runs/r-2a5c42e150/events.jsonl">
            <LogStream events={realLog} />
          </TerminalWindow>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">execution · tools/</span>
          <h2>The two tools.</h2>
          <p class="lead dim">
            Every micro-agent gets exactly these — <code>search</code> and <code>execute</code>.
            Both enforce <code>allowed_roots</code> as a hard security boundary.
          </p>
          <ul class="bullet-list">
            <li><strong>search</strong> — regex match, ripgrep or pure-Python. Rejects paths outside the allow-list.</li>
            <li><strong>execute</strong> — argv-only (no shell). Blocks sudo/su/doas. Caps stdout at 256 KB.</li>
          </ul>
        </div>
        <div>
          <TerminalWindow title="plnt/execution/tools/">
            <Code code={toolsCode} lang="python" theme="github-dark-default" />
          </TerminalWindow>
        </div>
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container">
      <span class="eyebrow">execution · sandbox/</span>
      <h2>The sandbox is a ladder.</h2>
      <p class="lead dim" style="max-width: 62ch;">
        Climb only when the threat model demands it. Two rungs ship; two are registered as stubs.
      </p>
      <div class="grid-4 mt-4">
        <div class="card">
          <span class="tag">rung 0 · shipping</span>
          <h3>process</h3>
          <p>Subprocess + rlimits + watchdog. The default. ~273 LOC at <code>sandbox/process.py</code>.</p>
        </div>
        <div class="card">
          <span class="tag">rung 1 · shipping</span>
          <h3>docker</h3>
          <p>CPU and memory caps, parallel-safe via labelled containers. ~290 LOC.</p>
        </div>
        <div class="card">
          <span class="tag">rung 2 · future</span>
          <h3>gVisor</h3>
          <p>User-space kernel isolation without the VM cost. Stub in the registry.</p>
        </div>
        <div class="card">
          <span class="tag">rung 3 · future</span>
          <h3>Firecracker µVM</h3>
          <p>Hard tenancy. Reserved for when the threat model demands it.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">skills</span>
          <h2>A skill is one markdown file.</h2>
          <p class="lead dim">
            Two files under <code>$PLNT_HOME/skills/&lt;role&gt;/</code> — a system prompt and a TOML manifest.
            The framework hot-reloads on file change. No SDK. No vendor.
          </p>
          <p>The example: <code>literature-scout</code>, an ephemeral scout the research-librarian spawns.</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <TerminalWindow title="skills/literature-scout/prompt.md">
            <Code code={skillPromptMd} lang="markdown" theme="github-dark-default" />
          </TerminalWindow>
          <TerminalWindow title="skills/literature-scout/skill.toml">
            <Code code={skillToml} lang="toml" theme="github-dark-default" />
          </TerminalWindow>
        </div>
      </div>
    </div>
  </section>

  <section class="section tinted">
    <div class="container narrow">
      <span class="eyebrow">compute</span>
      <h2>One router. Three backends.</h2>
      <p class="lead dim">
        Every model call resolves through <code>backend_picker.py</code> and is logged so
        <code>grep -F '"backend":"cloud"'</code> is a real audit query.
      </p>
      <div class="grid-3 mt-4">
        <div class="card">
          <span class="tag">01 · local</span>
          <h3>Ollama</h3>
          <p><code>PLNT_REQUIRED_PATH</code> mounted and <code>PLNT_LOCAL_URL</code> reachable → local.</p>
        </div>
        <div class="card">
          <span class="tag">02 · cloud</span>
          <h3>OpenAI-compat</h3>
          <p><code>PLNT_CLOUD_URL</code> + <code>PLNT_CLOUD_API_KEY</code> set and reachable → cloud fallback.</p>
        </div>
        <div class="card">
          <span class="tag">03 · offline</span>
          <h3>Deterministic echo</h3>
          <p>No backend reachable → deterministic echo. The test suite runs against this — no LLM required.</p>
        </div>
      </div>
      <div class="center mt-5">
        <a class="btn brand" href="/docs/concepts/four-planes/">Read the docs <span class="arrow">→</span></a>
        <a class="btn" style="margin-left: 0.5rem;" href="/roadmap">Roadmap</a>
      </div>
    </div>
  </section>

</Layout>

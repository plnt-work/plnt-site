---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '/' } = Astro.props;
const canonical = new URL(path, Astro.site).toString();
const ogImage = new URL('/og.png', Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'plnt',
  description: 'A local-first agent runtime. One resident planner spawns a swarm of sandboxed micro-agents on your hardware.',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  url: 'https://plnt.dev',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="plnt" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0c0c0c" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-nav">
      <div class="container inner">
        <a href="/" class="brand bare">
          <span class="logomark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="16" width="14" height="5" />
              <line x1="12" y1="16" x2="12" y2="7" />
              <path d="M12 12 Q7.5 11 6.5 6 Q11 7 12 12 Z" />
              <path d="M12 9 Q16 8.5 17 5 Q13 5.5 12 9 Z" />
            </svg>
          </span>
          <span>plnt</span>
        </a>
        <nav>
          <a href="/architecture">Architecture</a>
          <a href="/docs/">Docs</a>
          <a href="/roadmap">Roadmap</a>
          <a href="/resources">Resources</a>
        </nav>
        <div class="right">
          <a href="https://github.com/devdattatalele/plnt" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container inner">
        <span>plnt — runs on your hardware. Apache-2.0.</span>
        <div class="links">
          <a href="/architecture">Architecture</a>
          <a href="/docs/">Docs</a>
          <a href="/roadmap">Roadmap</a>
          <a href="/resources">Resources</a>
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="https://github.com/devdattatalele/plnt" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>

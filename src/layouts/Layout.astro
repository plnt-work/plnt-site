---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '/' } = Astro.props;
const canonical = new URL(path, Astro.site).toString();
const ogImage = new URL('/og.png', Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'plnt',
  description: 'The orchestration runtime for agentic workflows on Kubernetes. Pick a workflow from the registry, pick a GPU backend, and plnt handles the Helm deploy, canary, and rollback.',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux · Kubernetes',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  url: 'https://plnt.work',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  copyrightYear: 2026,
  copyrightHolder: {
    '@type': 'Organization',
    name: 'plnt.work',
    url: 'https://plnt.work',
    sameAs: ['https://github.com/plnt-work'],
  },
  publisher: {
    '@type': 'Organization',
    name: 'plnt.work',
    url: 'https://plnt.work',
    logo: 'https://plnt.work/favicon.svg',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="plnt" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#ffffff" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="announce" href="/architecture">
      <span class="pill">New</span>
      <span>plnt v0.1 — the orchestration runtime for agentic workflows</span>
      <span class="arrow">→</span>
    </a>
    <header class="site-nav">
      <div class="container inner">
        <a href="/" class="brand">
          <span class="logomark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="16" width="14" height="5" rx="1" />
              <line x1="12" y1="16" x2="12" y2="7" />
              <path d="M12 12 Q7.5 11 6.5 6 Q11 7 12 12 Z" />
              <path d="M12 9 Q16 8.5 17 5 Q13 5.5 12 9 Z" />
            </svg>
          </span>
          <span>plnt</span>
        </a>
        <nav>
          <a href="/playground">Playground</a>
          <a href="/architecture">Architecture</a>
          <a href="/docs/">Docs</a>
          <a href="/roadmap">Roadmap</a>
          <a href="/resources">Resources</a>
        </nav>
        <div class="right">
          <a class="gh" href="https://github.com/plnt-work/plnt" target="_blank" rel="noopener">GitHub ↗</a>
          <a class="nav-cta" href="https://play.plnt.work" target="_blank" rel="noopener">
            Open playground
            <span class="dot" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container inner">
        <div class="footer-copy">
          <span>© 2026 <a href="https://github.com/plnt-work" target="_blank" rel="noopener">plnt.work</a>. Apache-2.0 licensed.</span>
          <span class="footer-sub">The runtime for agentic workflows on Kubernetes.</span>
        </div>
        <div class="links">
          <a href="/playground">Playground</a>
          <a href="/architecture">Architecture</a>
          <a href="/docs/">Docs</a>
          <a href="/roadmap">Roadmap</a>
          <a href="/resources">Resources</a>
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="https://github.com/plnt-work/plnt" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
